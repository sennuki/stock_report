---
interface Props {
  reportData: any;
}

const { reportData } = Astro.props;

const brokers = [
  { name: "マネックス証券", nameEn: "Monex Securities", key: "is_available_monex", url: "https://h.accesstrade.net/sp/cc?rk=0100h3pw00oqmq", isPR: true },
  { name: "楽天証券", nameEn: "Rakuten Securities", key: "is_available_rakuten", url: "https://www.rakuten-sec.co.jp/web/market/search/us_search/result.html?all=on&vall=on&forwarding=na&target=0&theme=na&returns=na&head_office=na&name=&code=&sector=na&pageNo=&c=us&p=result&r1=on", isPR: false },
  { name: "SBI証券", nameEn: "SBI Securities", key: "is_available_sbi", url: "https://search.sbisec.co.jp/v2/popwin/info/stock/pop6040_usequity_list.html#us", isPR: false },
  { name: "三菱UFJ eスマート証券", nameEn: "Mitsubishi UFJ eSmart Securities", key: "is_available_mufg", url: "https://kabu.com/item/foreign_stock/us_stock/meigara.html", isPR: false },
  { name: "松井証券", nameEn: "Matsui Securities", key: "is_available_matsui", url: "https://h.accesstrade.net/sp/cc?rk=0100p10300oqmq", isPR: true },
  { name: "DMM株", nameEn: "DMM.com Securities", key: "is_available_dmm", url: "https://h.accesstrade.net/sp/cc?rk=0100mkk300oqmq", isPR: true },
  { name: "PayPay証券", nameEn: "PayPay Securities", key: "is_available_paypay", url: "https://www.paypay-sec.co.jp/us-stock/list/", isPR: false },
  { name: "moomoo証券", nameEn: "moomoo Securities", key: "is_available_moomoo", url: "https://h.accesstrade.net/sp/cc?rk=0100pd0z00oqmq", isPR: true },
  { name: "岩井コスモ証券", nameEn: "IwaiCosmo Securities", key: "is_available_iwaicosmo", url: "https://www.iwaicosmo.co.jp/investment/list/", isPR: false },
];
---

<section id="japan-brokers" class="mt-20 border-t-2 border-skin-accent/20 pt-10 pb-8">
  <h2 class="text-2xl font-bold mb-2 flex items-center gap-2">
    <span class="material-symbols-outlined text-skin-accent" aria-hidden="true">price_change</span> 日本の証券会社での購入可否
  </h2>
  <p class="text-xs text-gray-500 mb-6 italic flex items-center gap-1">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    本セクションには広告・プロモーションが含まれる場合があります。
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    {brokers.map((broker) => {
      const isAvailable = reportData[broker.key];
      return (
        <div class={`p-6 rounded-lg border-2 flex flex-col justify-between bg-transparent ${isAvailable ? 'border-green-500/30' : 'border-gray-300'}`}>
          <div class="flex items-center gap-4 mb-6">
            <div class={`p-3 rounded-full ${isAvailable ? 'bg-green-50 text-green-600' : 'bg-gray-100 text-gray-400'}`}>
              {isAvailable ? (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              ) : (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              )}
            </div>
            <div>
              <h3 class="text-xl font-bold text-skin-base">{broker.name}</h3>
              <p class="text-sm opacity-70">{broker.nameEn}</p>
            </div>
          </div>
          <div class="flex flex-col gap-3">
            <span class={`w-full text-center py-2 rounded-full font-bold text-sm ${isAvailable ? 'bg-green-600 text-white' : 'bg-gray-400 text-white'}`}>
              {isAvailable ? '購入可能' : '取扱なし'}
            </span>
            <div class="mt-2 pt-3 border-t border-skin-line/50">
              <a href={broker.url} rel={broker.isPR ? "nofollow sponsored" : ""} referrerpolicy="no-referrer-when-downgrade" target="_blank" class="text-xs text-skin-accent hover:underline flex items-center justify-center gap-1">
                {broker.isPR ? '公式サイトを確認 (PR)' : '公式サイトを確認'}
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      );
    })}
  </div>

  <p class="text-xs text-gray-500 mt-6 bg-skin-fill/50 p-4 rounded border border-skin-line italic">
    ※本データは各証券会社が公開している「取扱銘柄リスト」に基づき自動判定されています。最新の取扱状況や、売買停止・特定口座の対応状況については必ず各証券会社の公式サイトをご確認ください。
  </p>
</section>
