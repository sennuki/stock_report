---
interface Props {
  chartData: any;
  title?: string;
  id: string;
  height?: number;
  yAxisPosition?: 'left' | 'right';
}

const { chartData, title, id, height = 450, yAxisPosition = 'left' } = Astro.props;
---

<div
  class="chartjs-wrapper mt-24 mb-8 bg-transparent"
  data-chart={JSON.stringify(chartData || {})}
  data-symbol={chartData?.symbol}
  data-y-axis-position={yAxisPosition}
>
  {title && <h3 class="text-2xl font-bold mb-8 text-foreground">{title}</h3>}
  {chartData && chartData.error ? (
    <div class="flex items-center justify-center h-[200px] border border-dashed border-skin-line rounded-lg">
      <p class="text-skin-base opacity-70 italic">{chartData.error}</p>
    </div>
  ) : (
    <>
      <div class="chartjs-graph-div w-full relative" style={`height: ${height}px;`}>
        <canvas id={id}></canvas>
      </div>
      <div class="chart-actions flex justify-end gap-2 mt-3">
        <button
          type="button"
          class="chart-download-btn inline-flex items-center gap-1.5 px-3 py-1.5 text-xs rounded-md border border-skin-line bg-skin-card hover:border-skin-accent hover:text-skin-accent transition-colors"
          data-canvas-id={id}
          aria-label="グラフを画像として保存"
          title="グラフを画像として保存（PNG）"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3" />
          </svg>
          <span>画像を保存</span>
        </button>
      </div>
    </>
  )}
</div>

<script>
  import Chart from 'chart.js/auto';

  function getThemeColors() {
    const html = document.documentElement;
    const isDark = html.classList.contains('dark') || html.getAttribute('data-theme') === 'dark';
    return {
      isDark,
      textColor: isDark ? '#e5e7eb' : '#1f2937',
      gridColor: isDark ? 'rgba(255, 255, 255, 0.15)' : 'rgba(0, 0, 0, 0.1)'
    };
  }

  // chart データから Chart.js の type を推定する。
  //   - dataset.data の各要素が {x, y} オブジェクトなら scatter
  //   - dataset 個別に type 指定があれば mixed (chart 全体の type は最初の dataset に従う)
  //   - borderColor だけ持ち backgroundColor が無い → line
  //   - それ以外 (labels + 数値配列) → bar
  function detectChartType(srcData: any): string {
    const datasets = srcData.datasets || [];
    if (datasets.length === 0) return 'bar';

    const first = datasets[0];
    const sample = Array.isArray(first.data) ? first.data[0] : null;

    // scatter: {x, y} 形式の data
    if (sample && typeof sample === 'object' && 'x' in sample && 'y' in sample) {
      return 'scatter';
    }

    // 各 dataset に明示的な type が指定されていれば mixed として最初の type を返す
    const explicitTypes = datasets.map((d: any) => d.type).filter(Boolean);
    if (explicitTypes.length > 0) return explicitTypes[0];

    // line chart の特徴: fill === false かつ borderColor あり (background なし or 透明)
    const looksLikeLine = first.fill === false || (!!first.borderColor && !first.backgroundColor);
    if (looksLikeLine) return 'line';

    return 'bar';
  }

  function applyThemeColors(chart: any) {
    const { textColor, gridColor, isDark } = getThemeColors();
    chart.options.color = textColor;
    if (chart.options.scales) {
      for (const key of Object.keys(chart.options.scales)) {
        const scale = chart.options.scales[key];
        if (scale.ticks) scale.ticks.color = textColor;
        if (scale.grid) {
          scale.grid.color = key === 'y'
            ? (ctx: any) => ctx.tick?.value === 0
                ? (isDark ? 'rgba(229, 231, 235, 0.4)' : 'rgba(31, 41, 55, 0.4)')
                : gridColor
            : gridColor;
        }
      }
    }
    if (chart.options.plugins?.legend?.labels) {
      chart.options.plugins.legend.labels.color = textColor;
    }
    chart.update('none');
  }

  function formatYValueAbbreviated(v: any, isPercent: boolean, isPerformance = false, canvasId = '') {
    if (v === null || v === undefined || isNaN(v)) return '';
    if (isPercent) {
      const isFinRatio = ['chart-is', 'chart-tp'].includes(canvasId);
      const decimals = (isPerformance || isFinRatio) ? 1 : 2;
      return (parseFloat(v) * 100).toFixed(decimals) + '%';
    }
    const absV = Math.abs(v);
    if (absV >= 1e12) return (v / 1e12).toFixed(1) + 'T';
    if (absV >= 1e9) return (v / 1e9).toFixed(1) + 'B';
    if (absV >= 1e6) return (v / 1e6).toFixed(1) + 'M';
    return v.toLocaleString();
  }

  function formatYValueMillions(v: any, isPercent: boolean) {
    if (v === null || v === undefined || isNaN(v)) return '';
    if (isPercent) return (parseFloat(v) * 100).toFixed(2) + '%';
    const absV = Math.abs(v);
    if (absV > 0 && absV < 100000) return v.toLocaleString();
    return Math.round(v / 1e6).toLocaleString() + 'M';
  }

  function buildConfig(srcData: any, canvasId: string, yAxisPosition: string) {
    const { textColor, gridColor, isDark } = getThemeColors();
    const chartType = detectChartType(srcData);
    const isScatter = chartType === 'scatter';
    const isPerformance = canvasId === 'chart-performance' || chartType === 'line';

    // y1 軸を使う dataset があれば右側 y 軸を有効化
    const hasY1 = (srcData.datasets || []).some((d: any) => d.yAxisID === 'y1');

    // bar の積み上げ: chart-bs / chart-cf / chart-segment / chart-geo は stack を使う
    const stackedCharts = ['chart-bs', 'chart-cf', 'chart-segment', 'chart-geo'];
    const stacked = stackedCharts.includes(canvasId);

    return {
      type: chartType as any,
      data: {
        labels: srcData.labels || undefined,
        datasets: srcData.datasets || [],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: { duration: 400 },
        color: textColor,
        layout: { padding: { right: isPerformance ? 60 : 0 } },
        interaction: { mode: isScatter ? 'nearest' : 'index', intersect: isScatter },
        plugins: {
          legend: {
            position: 'top',
            labels: { color: textColor, usePointStyle: true },
          },
          tooltip: {
            callbacks: {
              label: (context: any) => {
                if (isScatter) {
                  const p = context.raw;
                  const sym = p.symbol || context.dataset.label;
                  return `${sym} - リスク: ${(p.x * 100).toFixed(1)}%, リターン: ${(p.y * 100).toFixed(1)}%`;
                }
                const value = context.raw;
                if (isPerformance && typeof value === 'number') {
                  const pct = value * 100;
                  return context.dataset.label + ': ' + (pct >= 0 ? '+' : '') + pct.toFixed(1) + '%';
                }
                return context.dataset.label + ': ' + formatYValueMillions(value, context.dataset.yAxisID === 'y1');
              },
            },
          },
        },
        scales: {
          x: {
            type: isScatter ? 'linear' : 'category',
            grid: { color: gridColor },
            stacked: stacked && !isScatter,
            ticks: {
              color: textColor,
              maxTicksLimit: 8,
              autoSkip: true,
              callback: function(this: any, val: any): any {
                if (isScatter) return (val * 100).toFixed(0) + '%';
                const label: any = this.getLabelForValue(val);
                if (typeof label === 'string') {
                  const datePart = label.split('T')[0];
                  if (datePart.match(/^\d{4}-\d{2}-\d{2}$/)) return datePart.replace(/-/g, '/');
                  return datePart;
                }
                return label;
              },
            },
          },
          y: {
            type: 'linear',
            position: yAxisPosition as any,
            stacked: stacked,
            beginAtZero: !isScatter,
            grid: {
              color: (ctx: any) => ctx.tick?.value === 0
                ? (isDark ? 'rgba(229, 231, 235, 0.4)' : 'rgba(31, 41, 55, 0.4)')
                : gridColor,
              lineWidth: (ctx: any) => ctx.tick?.value === 0 ? 2 : 1,
            },
            ticks: {
              color: textColor,
              callback: (value: any) => formatYValueAbbreviated(value, isScatter || isPerformance, isPerformance, canvasId),
            },
          },
          ...(hasY1 ? {
            y1: {
              type: 'linear',
              position: 'right',
              grid: { drawOnChartArea: false },
              ticks: {
                color: textColor,
                callback: (value: any) => formatYValueAbbreviated(value, true, false, canvasId),
              },
            },
          } : {}),
        },
      },
    };
  }

  function renderChartJs(canvas: HTMLCanvasElement, srcData: any) {
    if (!srcData || !srcData.datasets || srcData.datasets.length === 0) return;

    const wrapper = canvas.closest('.chartjs-wrapper') as HTMLElement | null;
    const yAxisPosition = wrapper?.dataset.yAxisPosition || 'left';
    const config = buildConfig(srcData, canvas.id, yAxisPosition);

    // 既存のチャートを破棄
    const existing = Chart.getChart(canvas);
    if (existing) existing.destroy();
    if ((canvas as any)._chart_instance && typeof (canvas as any)._chart_instance.destroy === 'function') {
      (canvas as any)._chart_instance.destroy();
    }

    const chart = new Chart(canvas, {
      ...config as any,
      plugins: [
        {
          // 棒グラフ内に値ラベルを描画
          id: 'barDataLabels',
          afterDatasetsDraw: (chart: any) => {
            const targetIds = ['chart-bs', 'chart-is', 'chart-cf', 'chart-tp', 'chart-dps', 'chart-segment', 'chart-geo'];
            if (!targetIds.includes(canvas.id)) return;
            const { ctx, data } = chart;
            ctx.save();
            data.datasets.forEach((ds: any, i: number) => {
              const meta = chart.getDatasetMeta(i);
              if (meta.hidden || !chart.isDatasetVisible(i) || (ds.type && ds.type !== 'bar') || (!ds.type && config.type !== 'bar')) return;
              meta.data.forEach((element: any, idx: number) => {
                const v = ds.data[idx];
                if (v === null || v === 0) return;
                const h = element.height || (element.y - element.base);
                if (Math.abs(h) < 12) return;
                const label = formatYValueAbbreviated(v, false);
                ctx.fillStyle = '#ffffff';
                ctx.font = 'bold 10px sans-serif';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText(label, element.x, element.y + h / 2);
              });
            });
            ctx.restore();
          },
        },
        {
          // ライン末尾に最終値ラベル (パフォーマンスチャート用)
          id: 'latestValueLabel',
          afterDatasetsDraw: (chart: any) => {
            if (chart.config.type === 'scatter') return;
            const isPerf = canvas.id === 'chart-performance';
            if (!isPerf) return;
            const { ctx } = chart;
            ctx.save();
            chart.data.datasets.forEach((ds: any, i: number) => {
              if (!chart.isDatasetVisible(i)) return;
              const meta = chart.getDatasetMeta(i);
              if (!meta.data || meta.data.length === 0) return;
              let lastIdx = -1;
              for (let j = ds.data.length - 1; j >= 0; j--) {
                if (ds.data[j] !== null && ds.data[j] !== undefined) { lastIdx = j; break; }
              }
              if (lastIdx === -1) return;
              const last = meta.data[lastIdx];
              if (!last || last.skip) return;
              const val = ds.data[lastIdx] * 100;
              const text = (val >= 0 ? '+' : '') + val.toFixed(1) + '%';
              ctx.fillStyle = ds.borderColor;
              ctx.font = 'bold 11px sans-serif';
              ctx.textAlign = 'left';
              ctx.textBaseline = 'middle';
              ctx.fillText(text, last.x + 8, last.y);
            });
            ctx.restore();
          },
        },
      ],
    });
    (canvas as any)._chart_instance = chart;
  }

  function initChartJs() {
    const { textColor } = getThemeColors();
    Chart.defaults.color = textColor;

    document.querySelectorAll('.chartjs-graph-div canvas').forEach(canvas => {
      const inst = (canvas as any)._chart_instance;
      if ((canvas as any)._chart_initialized && inst) {
        applyThemeColors(inst);
        return;
      }
      const wrapper = (canvas as HTMLElement).closest('.chartjs-wrapper') as HTMLElement | null;
      if (!wrapper) return;
      const chartData = JSON.parse(wrapper.dataset.chart || '{}');
      renderChartJs(canvas as HTMLCanvasElement, chartData);
      (canvas as any)._chart_initialized = true;
    });
  }

  function downloadChartImage(canvasId: string) {
    const canvas = document.getElementById(canvasId) as HTMLCanvasElement | null;
    if (!canvas) return;
    const isDark = document.documentElement.classList.contains('dark') ||
                   document.documentElement.getAttribute('data-theme') === 'dark';
    const bgColor = isDark ? '#1e1e1e' : '#ffffff';
    const watermarkColor = isDark ? 'rgba(229,231,235,0.55)' : 'rgba(31,41,55,0.55)';
    const wrapper = canvas.closest('.chartjs-wrapper') as HTMLElement | null;
    const chartData = wrapper ? JSON.parse(wrapper.dataset.chart || '{}') : {};
    const symbol = wrapper?.dataset?.symbol || chartData?.symbol || '';
    const titleEl = wrapper?.querySelector('h3');
    const titleText = titleEl?.textContent?.trim() || '';

    const padding = 40;
    const headerHeight = (titleText || symbol) ? 80 : 0;
    const footerHeight = 40;
    const outW = canvas.width + padding * 2;
    const outH = canvas.height + headerHeight + footerHeight + padding;

    const out = document.createElement('canvas');
    out.width = outW;
    out.height = outH;
    const ctx = out.getContext('2d');
    if (!ctx) return;

    ctx.fillStyle = bgColor;
    ctx.fillRect(0, 0, outW, outH);

    if (titleText || symbol) {
      ctx.fillStyle = isDark ? '#e5e7eb' : '#1f2937';
      ctx.font = 'bold 22px system-ui, -apple-system, sans-serif';
      ctx.textBaseline = 'top';
      ctx.textAlign = 'left';
      let header = '';
      if (symbol) header += symbol;
      if (symbol && titleText) header += '  -  ';
      if (titleText) header += titleText;
      ctx.fillText(header, padding, padding / 2 + 10);
    }

    ctx.drawImage(canvas, padding, headerHeight + padding / 2);

    ctx.fillStyle = watermarkColor;
    ctx.font = '12px system-ui, -apple-system, sans-serif';
    ctx.textBaseline = 'bottom';
    ctx.textAlign = 'right';
    const url = (window.location.origin || '') + window.location.pathname;
    ctx.fillText(url, outW - padding, outH - 12);
    ctx.textAlign = 'left';
    ctx.fillText(`Generated: ${new Date().toISOString().slice(0, 10)}`, padding, outH - 12);

    const dataUrl = out.toDataURL('image/png');
    const a = document.createElement('a');
    const safeSymbol = (symbol || 'chart').replace(/[^A-Za-z0-9_-]/g, '');
    a.href = dataUrl;
    a.download = `${safeSymbol}_${canvasId}.png`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
  }

  function bindDownloadButtons() {
    document.querySelectorAll<HTMLButtonElement>('.chart-download-btn').forEach(btn => {
      if ((btn as any)._bound) return;
      (btn as any)._bound = true;
      btn.addEventListener('click', () => {
        const id = btn.dataset.canvasId;
        if (id) downloadChartImage(id);
      });
    });
  }

  initChartJs();
  bindDownloadButtons();

  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.chartjs-graph-div canvas').forEach(c => {
      (c as any)._chart_initialized = false;
    });
    setTimeout(() => {
      initChartJs();
      bindDownloadButtons();
    }, 50);
  });

  const themeObserver = new MutationObserver(() => initChartJs());
  themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme', 'class'] });
</script>
