  },
  // 生産性
  "revenue-per-employee": {
    metricKey: "revenue_per_employee",
    label: "売上 / 従業員ランキング",
    subtitle: "従業員1人あたり売上が大きい順 — 労働生産性",
  },
  "mcap-per-employee": {
    metricKey: "mcap_per_employee",
    label: "時価総額 / 従業員ランキング",
    subtitle: "従業員1人あたり時価総額が大きい順 — 1人あたり評価額",
  },
  // 株価・リスク
  "stock-price": {
    metricKey: "stock_price",
    label: "株価 (1株あたり) ランキング",
    subtitle: "1株あたり株価が高い順",
  },
  "range-position-52w": {
    metricKey: "range_position_52w",
    label: "52週レンジ内位置ランキング",
    subtitle: "52週高値に近い順 — 高値圏ブレイク候補",
  },
  "beta": {
    metricKey: "beta",
    label: "ベータランキング",
    subtitle: "ベータ値が大きい順 — 市場連動性が高い高ボラ銘柄",
  },
  // アナリスト評価
  "analyst-count": {
    metricKey: "analyst_count",
    label: "アナリスト数ランキング",
    subtitle: "カバーするアナリストの人数が多い順 — 市場の注目度",
  },
  "target-upside": {
    metricKey: "target_upside",
    label: "目標株価乖離率ランキング",
    subtitle: "現在株価と目標株価コンセンサス (mean) の乖離率が大きい順 — アップサイド候補",
