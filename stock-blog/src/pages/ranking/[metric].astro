  },
  "analyst-bear-ratio": {
    metricKey: "analyst_bear_ratio",
    label: "弱気評価比率ランキング",
    subtitle: "Sell + Strong Sell の割合が高い順 — 逆張り候補 / 警戒銘柄",
  },
  // 財務健全性
  "debt-to-equity-low": {
    metricKey: "debt_to_equity_low",
    label: "D/E 比率 (低) ランキング",
    subtitle: "負債資本比率が低い順 — 健全な財務体質の銘柄",
  },
  "current-ratio": {
    metricKey: "current_ratio",
    label: "流動比率ランキング",
    subtitle: "流動資産 ÷ 流動負債 が高い順 — 短期の支払能力に余裕",
  },
  "quick-ratio": {
    metricKey: "quick_ratio",
    label: "当座比率ランキング",
    subtitle: "(流動資産 − 棚卸) ÷ 流動負債 が高い順 — 厳格な短期支払能力",
  },
  // キャッシュフロー
  "free-cashflow": {
    metricKey: "free_cashflow",
    label: "フリーキャッシュフローランキング",
    subtitle: "営業 CF − 設備投資 の絶対額が大きい順 — 創出するキャッシュの規模",
  },
  "fcf-margin": {
    metricKey: "fcf_margin",
    label: "FCF マージンランキング",
    subtitle: "FCF ÷ 売上 が高い順 — 売上をどれだけキャッシュに転換できているか",
  },
  // 株主構成
  "held-pct-institutions": {
    metricKey: "held_pct_institutions",
    label: "機関投資家保有率ランキング",
    subtitle: "機関投資家の保有比率が高い順 — プロのマネーが集まっている銘柄",
  },
  "held-pct-insiders": {
    metricKey: "held_pct_insiders",
    label: "インサイダー保有率ランキング",
    subtitle: "経営陣など内部関係者の保有比率が高い順 — 経営とのインセンティブ整合",
  },
  "short-pct-float": {
    metricKey: "short_pct_float",
    label: "空売り比率 (浮動株比) ランキング",
    subtitle: "浮動株に占める空売り残高比率が高い順 — スクイーズ候補 / 警戒銘柄",
  },
  // モメンタム
  "earnings-growth": {
    metricKey: "earnings_growth",
    label: "EPS 成長率 (YoY) ランキング",
    subtitle: "通期 EPS の前年比成長率が高い順",
  },
  "earnings-quarterly-growth": {
    metricKey: "earnings_quarterly_growth",
    label: "EPS 成長率 (四半期 YoY) ランキング",
    subtitle: "直近四半期 EPS の前年同期比成長率が高い順 — モメンタム指標",
  },
  // バリュエーション拡張
  "high-forward-pe": {
    metricKey: "high_forward_pe",
    label: "PER 予想 (高) ランキング",
    subtitle: "予想 PER が高い順 — 高成長プレミアムが乗っている銘柄",
  },
  "peg-ratio-low": {
    metricKey: "peg_ratio_low",
    label: "PEG レシオ (低) ランキング",
    subtitle: "PEG が低い順 — 成長を加味した割安度 (Lynch 指標)",
  },
  "enterprise-to-revenue": {
    metricKey: "enterprise_to_revenue",
    label: "EV / Revenue (低) ランキング",
    subtitle: "事業価値 ÷ 売上 が低い順 — 借入を加味した PSR の改良版",
  },
  "ebitda-margin": {
    metricKey: "ebitda_margin",
    label: "EBITDA マージンランキング",
    subtitle: "EBITDA ÷ 売上 が高い順 — キャッシュベースの収益性",
  },
  "earnings-yield": {
    metricKey: "earnings_yield",
    label: "Earnings Yield ランキング",
    subtitle: "EBIT ÷ EV が高い順 — Magic Formula の利回り要素",
  },
  "roic-proxy": {
    metricKey: "roic_proxy",
    label: "ROIC (推定) ランキング",
    subtitle: "EBIT ÷ (総資産 − 流動負債) が高い順 — Greenblatt 流の資本効率",
  },
  // 低ベータ / パフォーマンス
  "beta-low": {
    metricKey: "beta_low",
    label: "ベータ (低) ランキング",
    subtitle: "ベータが低い順 — 市場連動が低いディフェンシブ候補",
  },
  "return-1y": {
    metricKey: "return_1y",
    label: "1年リターンランキング",
    subtitle: "直近 1 年の年率リターンが高い順",
  },
  "return-ytd": {
    metricKey: "return_ytd",
    label: "年初来リターンランキング",
    subtitle: "年初来のパフォーマンス (年率換算) が高い順",
  },
  "max-drawdown-1y": {
    metricKey: "max_drawdown_1y",
    label: "最大ドローダウン (1年) ランキング",
    subtitle: "直近 1 年の最大下落幅が小さい順 — 下落耐性が高い銘柄",
  },
  // コンポジット
  "piotroski-score": {
    metricKey: "piotroski_score",
    label: "Piotroski F-Score ランキング",
    subtitle: "9 項目 (収益性・レバレッジ・効率) の財務健全性チェックを 0-9 点で評価",
  },
  "dividend-stability": {
    metricKey: "dividend_stability",
    label: "配当安定性スコアランキング",
    subtitle: "配当継続性・FCF カバー率・利益安定性など 5 項目を 0-5 点で評価",
  },
  "magic-formula": {
    metricKey: "magic_formula",
    label: "Magic Formula ランキング",
    subtitle: "Earnings Yield と ROIC の順位合計が小さい順 — Greenblatt 流のクオリティ × バリュー",
  },
};

const { metric } = Astro.params as { metric: string };
const config = METRIC_MAP[metric];

if (!config) {
  return Astro.redirect("/ranking");
}

let rankings: Record<string, any> = fallbackRankings as Record<string, any>;
try {
  const bucket = (env as any)?.STOCK_DATA;
  if (bucket) {
    const object = await bucket.get("reports/rankings.json");
    if (object) {
      const text = await object.text();
      rankings = JSON.parse(text);
    }
  }
} catch (e) {
  console.error("Failed to load rankings from R2", e);
}

const data = rankings[config.metricKey];
const entries: any[] = data?.top ?? [];
const unit: string = data?.unit ?? "ratio";

function fmtValue(v: number | null | undefined, unit: string): string {
  if (v == null || !Number.isFinite(v)) return "---";
  if (unit === "currency") {
    const abs = Math.abs(v);
    if (abs >= 1e12) return `$${(v / 1e12).toFixed(2)}T`;
    if (abs >= 1e9) return `$${(v / 1e9).toFixed(2)}B`;
    if (abs >= 1e6) return `$${(v / 1e6).toFixed(2)}M`;
    if (abs >= 1e3) return `$${(v / 1e3).toFixed(1)}K`;
    return `$${v.toFixed(0)}`;
  }
  if (unit === "percent") return `${(v * 100).toFixed(2)}%`;
  if (unit === "price") return `$${v.toFixed(2)}`;
  if (unit === "count") return v.toLocaleString();
  return v.toFixed(2);
}

const sectorTranslations: Record<string, string> = {
  "Communication Services": "通信サービス",
  "Consumer Discretionary": "一般消費財",
  "Consumer Staples": "生活必需品",
  Energy: "エネルギー",
  Financials: "金融",
  "Health Care": "ヘルスケア",
  Industrials: "資本財",
  "Information Technology": "情報技術",
  Materials: "素材",
  "Real Estate": "不動産",
  Utilities: "公益事業",
};

const title = `${config.label} - アメリカ株インサイト`;
const description = `${config.subtitle}。S&P 1500 銘柄のベスト${entries.length}ランキングをまとめています。`;
---

<Layout title={title} description={description}>
  <Header />
  <main id="main-content" class="app-layout">
    <section class="py-8">
      <nav class="text-sm opacity-70 mb-4">
        <a href="/ranking" class="hover:text-skin-accent">← ランキング一覧へ戻る</a>
      </nav>
      <h1 class="text-3xl font-bold mb-2">{config.label}</h1>
      <p class="opacity-80 mb-6">{config.subtitle}</p>

      {entries.length === 0 ? (
        <div class="p-6 border border-dashed border-skin-line rounded-lg">
          <p class="text-gray-500 italic">ランキングデータがまだ生成されていません。</p>
        </div>
      ) : (
        <div class="overflow-x-auto rounded-lg border border-skin-line">
          <table class="min-w-full text-sm">
            <thead class="bg-skin-fill/30 text-left">
              <tr>
                <th class="px-4 py-3 w-16">順位</th>
                <th class="px-4 py-3">銘柄</th>
                <th class="px-4 py-3 hidden sm:table-cell">セクター</th>
                <th class="px-4 py-3 text-right">{data?.label ?? "値"}</th>
              </tr>
            </thead>
            <tbody>
              {entries.map((e, i) => (
                <tr class="border-t border-skin-line/40 hover:bg-skin-fill/20">
                  <td class="px-4 py-2 font-bold opacity-80">{e.rank}</td>
                  <td class="px-4 py-2">
                    <a
                      href={`/report/${e.symbol_yf}`}
                      class="block hover:text-skin-accent"
                    >
                      <div class="font-mono font-bold">{e.symbol}</div>
                      <div class="text-xs opacity-70 truncate max-w-xs">
                        {e.security_ja || e.security}
                      </div>
                    </a>
                  </td>
                  <td class="px-4 py-2 hidden sm:table-cell text-xs opacity-70">
                    {sectorTranslations[e.sector] || e.sector || "---"}
                  </td>
                  <td class="px-4 py-2 text-right font-mono font-medium">
                    {fmtValue(e.value, unit)}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      <p class="text-xs text-gray-500 mt-6 italic">
        ※ データは yfinance ベース。財務指標は各社決算ベースで集計しています。母集団は S&P 500/400/600 の個別銘柄 (ETF を除く)。
      </p>
    </section>
    <Footer />
  </main>
</Layout>
