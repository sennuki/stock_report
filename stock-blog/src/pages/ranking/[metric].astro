  "analyst-buy-ratio": {
    metricKey: "analyst_buy_ratio",
    label: "Buy評価比率ランキング",
    subtitle: "Strong Buy + Buy の割合が高い順 — 5名以上のアナリスト評価がある銘柄が対象",
