  "recommendation-mean": {
    metricKey: "recommendation_mean",
    label: "コンセンサス推奨スコアランキング",
    subtitle: "推奨スコア (1=Strong Buy 〜 5=Sell) が低い (=ブル) 順",
  },
  "target-price-dispersion": {
    metricKey: "target_price_dispersion",
    label: "目標株価レンジ幅ランキング",
    subtitle: "(高値 − 安値) / 平均 が大きい順 — アナリスト間の意見の割れ度合い (3名以上対象)",
