  },
  "operating-margin": {
    metricKey: "operating_margin",
    label: "営業利益率ランキング",
    subtitle: "営業利益率が高い順 — 本業の収益性",
  },
  "gross-margin": {
    metricKey: "gross_margin",
    label: "粗利率ランキング",
    subtitle: "売上総利益率が高い順 — 製品/サービスの付加価値",
  },
  // バリュエーション
  "forward-pe": {
    metricKey: "forward_pe",
    label: "PER 割安ランキング (予想)",
    subtitle: "予想 PER (Forward P/E) が低い順 — バリュー候補",
  },
  "pbr": {
    metricKey: "pbr",
    label: "PBR 割安ランキング",
    subtitle: "株価純資産倍率 (PBR) が低い順 — 純資産に対する割安度",
  },
  "psr": {
    metricKey: "psr",
    label: "PSR 割安ランキング",
    subtitle: "株価売上高倍率 (PSR) が低い順 — 売上に対する割安度",
  },
  // 成長性
  "revenue-cagr-3y": {
    metricKey: "revenue_cagr_3y",
    label: "売上成長率ランキング (3年CAGR)",
    subtitle: "直近 3 年の売上年平均成長率が高い順",
  },
  "eps-9y-cagr": {
    metricKey: "eps_9y_cagr",
    label: "EPS 成長率ランキング (9年CAGR)",
