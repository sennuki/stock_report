---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import fallbackRankings from "@/data/rankings.json";
import { env } from "cloudflare:workers";

let rankings: Record<string, any> = fallbackRankings as Record<string, any>;

try {
  const bucket = (env as any)?.STOCK_DATA;
  if (bucket) {
    const object = await bucket.get("reports/rankings.json");
    if (object) {
      const text = await object.text();
      rankings = JSON.parse(text);
    }
  }
} catch (e) {
  console.error("Failed to load rankings from R2", e);
}

type RankingMetric = {
  slug: string;
  metricKey: string;
  label: string;
  description: string;
};

type RankingCategory = {
  title: string;
  metrics: RankingMetric[];
};

// カテゴリ別の指標定義
const CATEGORIES: RankingCategory[] = [
  {
    title: "規模感",
    metrics: [
      { slug: "market-cap", metricKey: "market_cap",
        label: "時価総額", description: "時価総額が大きい順 (米ドル建て)" },
      { slug: "revenue-ttm", metricKey: "revenue_ttm",
        label: "TTM 売上", description: "直近12ヶ月の売上高が大きい順" },
      { slug: "employees", metricKey: "employees",
        label: "従業員数", description: "従業員数が多い順" },
      { slug: "total-cash", metricKey: "total_cash",
        label: "現金保有額", description: "現金・短期投資の保有額が大きい順" },
    ],
  },
  {
    title: "収益性",
    metrics: [
      { slug: "roe", metricKey: "roe",
        label: "ROE", description: "自己資本利益率が高い順 (株主資本の効率)" },
      { slug: "roa", metricKey: "roa",
        label: "ROA", description: "総資産利益率が高い順 (資産の効率)" },
      { slug: "operating-margin", metricKey: "operating_margin",
        label: "営業利益率", description: "営業利益率が高い順" },
      { slug: "gross-margin", metricKey: "gross_margin",
        label: "粗利率", description: "売上総利益率が高い順" },
    ],
  },
  {
    title: "バリュエーション (割安)",
    metrics: [
      { slug: "forward-pe", metricKey: "forward_pe",
        label: "PER 予想 (割安)", description: "予想 PER が低い順 (バリュー候補)" },
      { slug: "pbr", metricKey: "pbr",
        label: "PBR (割安)", description: "株価純資産倍率が低い順" },
      { slug: "psr", metricKey: "psr",
        label: "PSR (割安)", description: "株価売上高倍率が低い順" },
    ],
  },
  {
    title: "成長性",
    metrics: [
      { slug: "revenue-cagr-3y", metricKey: "revenue_cagr_3y",
        label: "売上 3Y CAGR", description: "直近3年の売上年平均成長率が高い順" },
      { slug: "eps-9y-cagr", metricKey: "eps_9y_cagr",
        label: "EPS 9Y CAGR", description: "直近9年の EPS 年平均成長率が高い順" },
    ],
  },
  {
    title: "配当",
    metrics: [
      { slug: "dividend-yield", metricKey: "dividend_yield",
        label: "配当利回り", description: "配当利回り (年率) が高い順" },
      { slug: "dividend-rate", metricKey: "dividend_rate",
        label: "1株あたり配当", description: "1株あたり年間配当額が大きい順" },
    ],
  },
  {
    title: "生産性",
    metrics: [
      { slug: "revenue-per-employee", metricKey: "revenue_per_employee",
        label: "売上 / 従業員", description: "従業員1人あたり売上が大きい順" },
      { slug: "mcap-per-employee", metricKey: "mcap_per_employee",
        label: "時価総額 / 従業員", description: "従業員1人あたり時価総額が大きい順" },
    ],
  },
  {
    title: "株価・リスク",
    metrics: [
      { slug: "stock-price", metricKey: "stock_price",
        label: "株価 (1株あたり)", description: "1株あたり株価が高い順" },
      { slug: "range-position-52w", metricKey: "range_position_52w",
        label: "52週レンジ内位置", description: "52週高値に近い順 (上値ブレイク候補)" },
      { slug: "beta", metricKey: "beta",
        label: "ベータ", description: "ベータ値が大きい順 (高ボラ銘柄)" },
    ],
  },
];

const title = "銘柄ランキング (ベスト100) - アメリカ株インサイト";
const description = "時価総額・配当利回り・PER・成長率など、S&P 1500 銘柄のベスト100ランキングを多数の指標で網羅。";
---

<Layout title={title} description={description}>
  <Header />
  <main id="main-content" class="app-layout">
    <section class="py-8">
      <h1 class="text-3xl font-bold mb-2">銘柄ランキング (ベスト100)</h1>
      <p class="opacity-80 mb-8">S&P 500 / 400 / 600 を母集団とした各指標ベスト100ランキングです。気になる切り口から銘柄を発掘できます。</p>

      {CATEGORIES.map((category) => {
        const visibleMetrics = category.metrics.filter((m) => rankings[m.metricKey]?.top?.length);
        if (visibleMetrics.length === 0) return null;
        return (
          <div class="mb-10">
            <h2 class="text-xl font-bold mb-4 pb-2 border-b border-skin-line text-skin-accent">{category.title}</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {visibleMetrics.map((m) => (
                <a
                  href={`/ranking/${m.slug}`}
                  class="block p-5 rounded-lg border border-skin-line bg-skin-fill/20 hover:bg-skin-fill/40 transition-colors"
                >
                  <h3 class="text-lg font-bold mb-1 text-skin-base">{m.label}</h3>
                  <p class="text-sm opacity-80">{m.description}</p>
                  <p class="text-xs opacity-60 mt-2">対象: {rankings[m.metricKey]?.total ?? 0} 銘柄</p>
                </a>
              ))}
            </div>
          </div>
        );
      })}

      {Object.keys(rankings).length === 0 && (
        <p class="text-gray-500 italic">ランキングデータがまだ生成されていません。</p>
      )}
    </section>
    <Footer />
  </main>
</Layout>
