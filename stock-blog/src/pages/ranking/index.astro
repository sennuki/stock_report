---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import fallbackRankings from "@/data/rankings.json";
import { env } from "cloudflare:workers";

let rankings: Record<string, any> = fallbackRankings as Record<string, any>;

try {
  const bucket = (env as any)?.STOCK_DATA;
  if (bucket) {
    const object = await bucket.get("reports/rankings.json");
    if (object) {
      const text = await object.text();
      rankings = JSON.parse(text);
    }
  }
} catch (e) {
  console.error("Failed to load rankings from R2", e);
}

type RankingMetric = {
  slug: string;
  metricKey: string;
  label: string;
  description: string;
};

type RankingCategory = {
  title: string;
  metrics: RankingMetric[];
};

// カテゴリ別の指標定義
const CATEGORIES: RankingCategory[] = [
  {
    title: "規模感",
    metrics: [
      { slug: "market-cap", metricKey: "market_cap",
        label: "時価総額", description: "時価総額が大きい順 (米ドル建て)" },
      { slug: "revenue-ttm", metricKey: "revenue_ttm",
        label: "TTM 売上", description: "直近12ヶ月の売上高が大きい順" },
      { slug: "employees", metricKey: "employees",
        label: "従業員数", description: "従業員数が多い順" },
      { slug: "total-cash", metricKey: "total_cash",
        label: "現金保有額", description: "現金・短期投資の保有額が大きい順" },
    ],
  },
  {
    title: "収益性",
    metrics: [
      { slug: "roe", metricKey: "roe",
        label: "ROE", description: "自己資本利益率が高い順 (株主資本の効率)" },
      { slug: "roa", metricKey: "roa",
        label: "ROA", description: "総資産利益率が高い順 (資産の効率)" },
      { slug: "operating-margin", metricKey: "operating_margin",
        label: "営業利益率", description: "営業利益率が高い順" },
      { slug: "gross-margin", metricKey: "gross_margin",
        label: "粗利率", description: "売上総利益率が高い順" },
    ],
  },
  {
    title: "バリュエーション (割安)",
    metrics: [
      { slug: "forward-pe", metricKey: "forward_pe",
        label: "PER 予想 (割安)", description: "予想 PER が低い順 (バリュー候補)" },
      { slug: "pbr", metricKey: "pbr",
        label: "PBR (割安)", description: "株価純資産倍率が低い順" },
      { slug: "psr", metricKey: "psr",
        label: "PSR (割安)", description: "株価売上高倍率が低い順" },
    ],
  },
  {
    title: "成長性",
    metrics: [
      { slug: "revenue-cagr-3y", metricKey: "revenue_cagr_3y",
        label: "売上 3Y CAGR", description: "直近3年の売上年平均成長率が高い順" },
      { slug: "eps-9y-cagr", metricKey: "eps_9y_cagr",
        label: "EPS 9Y CAGR", description: "直近9年の EPS 年平均成長率が高い順" },
    ],
  },
  {
    title: "配当",
    metrics: [
      { slug: "dividend-yield", metricKey: "dividend_yield",
        label: "配当利回り", description: "配当利回り (年率) が高い順" },
      { slug: "dividend-rate", metricKey: "dividend_rate",
        label: "1株あたり配当", description: "1株あたり年間配当額が大きい順" },
    ],
  },
  {
    title: "生産性",
    metrics: [
      { slug: "revenue-per-employee", metricKey: "revenue_per_employee",
        label: "売上 / 従業員", description: "従業員1人あたり売上が大きい順" },
      { slug: "mcap-per-employee", metricKey: "mcap_per_employee",
        label: "時価総額 / 従業員", description: "従業員1人あたり時価総額が大きい順" },
    ],
  },
  {
    title: "株価・リスク",
    metrics: [
      { slug: "stock-price", metricKey: "stock_price",
        label: "株価 (1株あたり)", description: "1株あたり株価が高い順" },
      { slug: "range-position-52w", metricKey: "range_position_52w",
        label: "52週レンジ内位置", description: "52週高値に近い順 (上値ブレイク候補)" },
      { slug: "beta", metricKey: "beta",
        label: "ベータ", description: "ベータ値が大きい順 (高ボラ銘柄)" },
    ],
  },
  {
    title: "アナリスト評価",
    metrics: [
      { slug: "analyst-count", metricKey: "analyst_count",
        label: "アナリスト数", description: "カバーするアナリストの人数が多い順 (注目度)" },
      { slug: "target-upside", metricKey: "target_upside",
        label: "目標株価乖離率", description: "現在株価と目標株価コンセンサスの乖離率が大きい順 (アップサイド候補)" },
      { slug: "analyst-buy-ratio", metricKey: "analyst_buy_ratio",
        label: "Buy評価比率", description: "Strong Buy + Buy の割合が高い順 (5名以上が評価する銘柄)" },
      { slug: "recommendation-mean", metricKey: "recommendation_mean",
        label: "コンセンサス推奨スコア", description: "推奨スコア (1=Strong Buy 〜 5=Sell) が低い順" },
      { slug: "target-price-dispersion", metricKey: "target_price_dispersion",
        label: "目標株価レンジ幅", description: "(High − Low) / Mean が大きい順 (アナリスト意見の割れ度合い)" },
      { slug: "analyst-strong-buy-ratio", metricKey: "analyst_strong_buy_ratio",
        label: "Strong Buy 専一率", description: "Strong Buy 単独の割合が高い順 (確信度の高い強気)" },
      { slug: "analyst-bear-ratio", metricKey: "analyst_bear_ratio",
        label: "弱気評価比率", description: "Sell + Strong Sell の割合が高い順 (逆張り/警戒候補)" },
    ],
  },
  {
    title: "財務健全性",
    metrics: [
      { slug: "debt-to-equity-low", metricKey: "debt_to_equity_low",
        label: "D/E 比率 (低)", description: "負債資本比率が低い順 (健全な財務体質)" },
      { slug: "current-ratio", metricKey: "current_ratio",
        label: "流動比率", description: "流動資産 / 流動負債 が高い順 (短期支払能力)" },
      { slug: "quick-ratio", metricKey: "quick_ratio",
        label: "当座比率", description: "(流動資産 − 棚卸) / 流動負債 が高い順 (厳格な短期支払能力)" },
    ],
  },
  {
    title: "キャッシュフロー",
    metrics: [
      { slug: "free-cashflow", metricKey: "free_cashflow",
        label: "フリーキャッシュフロー", description: "営業 CF − 設備投資 の絶対額が大きい順" },
      { slug: "fcf-margin", metricKey: "fcf_margin",
        label: "FCF マージン", description: "FCF / 売上 が高い順 (キャッシュ創出力)" },
    ],
  },
  {
    title: "株主構成・空売り",
    metrics: [
      { slug: "held-pct-institutions", metricKey: "held_pct_institutions",
        label: "機関投資家保有率", description: "機関投資家の保有比率が高い順" },
      { slug: "held-pct-insiders", metricKey: "held_pct_insiders",
        label: "インサイダー保有率", description: "経営陣など内部関係者の保有比率が高い順" },
      { slug: "short-pct-float", metricKey: "short_pct_float",
        label: "空売り比率 (浮動株比)", description: "浮動株に占める空売り比率が高い順 (スクイーズ候補)" },
    ],
  },
  {
    title: "直近モメンタム",
    metrics: [
      { slug: "earnings-growth", metricKey: "earnings_growth",
        label: "EPS 成長率 (YoY)", description: "直近の EPS YoY 成長率が高い順" },
      { slug: "earnings-quarterly-growth", metricKey: "earnings_quarterly_growth",
        label: "EPS 成長率 (四半期 YoY)", description: "直近四半期 EPS の YoY 成長率が高い順" },
    ],
  },
  {
    title: "バリュエーション (拡張)",
    metrics: [
      { slug: "high-forward-pe", metricKey: "high_forward_pe",
        label: "PER 予想 (高)", description: "予想 PER が高い順 (高成長プレミアム銘柄)" },
      { slug: "peg-ratio-low", metricKey: "peg_ratio_low",
        label: "PEG レシオ (低)", description: "PEG が低い順 (成長を加味した割安度)" },
      { slug: "enterprise-to-revenue", metricKey: "enterprise_to_revenue",
        label: "EV / Revenue (低)", description: "事業価値÷売上 が低い順 (PSR の改良版)" },
      { slug: "ebitda-margin", metricKey: "ebitda_margin",
        label: "EBITDA マージン", description: "EBITDA / 売上 が高い順 (キャッシュベース収益性)" },
      { slug: "earnings-yield", metricKey: "earnings_yield",
        label: "Earnings Yield", description: "EBIT / EV が高い順 (Magic Formula の利回り要素)" },
      { slug: "roic-proxy", metricKey: "roic_proxy",
        label: "ROIC (推定)", description: "EBIT / (総資産 − 流動負債) が高い順 (資本効率)" },
    ],
  },
  {
    title: "パフォーマンス・低ボラ",
    metrics: [
      { slug: "beta-low", metricKey: "beta_low",
        label: "ベータ (低)", description: "ベータが低い順 (ディフェンシブ候補)" },
      { slug: "return-1y", metricKey: "return_1y",
        label: "1年リターン", description: "直近 1 年の年率リターンが高い順" },
      { slug: "return-ytd", metricKey: "return_ytd",
        label: "年初来リターン", description: "年初来パフォーマンス (年率換算) が高い順" },
      { slug: "max-drawdown-1y", metricKey: "max_drawdown_1y",
        label: "最大ドローダウン (1年)", description: "直近 1 年の最大下落が小さい順 (耐性が高い)" },
    ],
  },
  {
    title: "コンポジット・スコア",
    metrics: [
      { slug: "piotroski-score", metricKey: "piotroski_score",
        label: "Piotroski F-Score", description: "9 項目の財務健全性スコア (0-9) が高い順" },
      { slug: "dividend-stability", metricKey: "dividend_stability",
        label: "配当安定性スコア", description: "配当継続性・健全性の 5 項目スコアが高い順" },
      { slug: "magic-formula", metricKey: "magic_formula",
        label: "Magic Formula", description: "Earnings Yield と ROIC の順位合計が小さい順 (Greenblatt 流)" },
    ],
  },
];

const title = "銘柄ランキング (ベスト100) - アメリカ株インサイト";
const description = "時価総額・配当利回り・PER・成長率など、S&P 1500 銘柄のベスト100ランキングを多数の指標で網羅。";
---

<Layout title={title} description={description}>
  <Header />
  <main id="main-content" class="app-layout">
    <section class="py-8">
      <h1 class="text-3xl font-bold mb-2">銘柄ランキング (ベスト100)</h1>
      <p class="opacity-80 mb-8">S&P 500 / 400 / 600 を母集団とした各指標ベスト100ランキングです。気になる切り口から銘柄を発掘できます。</p>

      {CATEGORIES.map((category) => {
        const visibleMetrics = category.metrics.filter((m) => rankings[m.metricKey]?.top?.length);
        if (visibleMetrics.length === 0) return null;
        return (
          <div class="mb-10">
            <h2 class="text-xl font-bold mb-4 pb-2 border-b border-skin-line text-skin-accent">{category.title}</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {visibleMetrics.map((m) => (
                <a
                  href={`/ranking/${m.slug}`}
                  class="block p-5 rounded-lg border border-skin-line bg-skin-fill/20 hover:bg-skin-fill/40 transition-colors"
                >
                  <h3 class="text-lg font-bold mb-1 text-skin-base">{m.label}</h3>
                  <p class="text-sm opacity-80">{m.description}</p>
                  <p class="text-xs opacity-60 mt-2">対象: {rankings[m.metricKey]?.total ?? 0} 銘柄</p>
                </a>
              ))}
            </div>
          </div>
        );
      })}

      {Object.keys(rankings).length === 0 && (
        <p class="text-gray-500 italic">ランキングデータがまだ生成されていません。</p>
      )}
    </section>
    <Footer />
  </main>
</Layout>
