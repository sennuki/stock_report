---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import stocksData from "@/data/stocks.json";
import dayjs from "dayjs";

interface Stock {
  Symbol_YF: string;
  Security: string;
  Security_JA?: string;
  "GICS Sector": string;
  "GICS Sub-Industry": string;
  Earnings_Date?: string;
  [key: string]: any;
}

const stocks: Stock[] = stocksData as Stock[];

// Check if earnings was within the last 7 days
// 実績データ (Actual_Earnings_Date) が直近7日以内かどうかで判定する
const isRecentEarnings = (stock?: Stock) => {
  return stock?.Is_Recent_Actual === true;
};

const sectorTranslations: Record<string, string> = {
  "Communication Services": "通信サービス",
  "Consumer Discretionary": "一般消費財",
  "Consumer Staples": "生活必需品",
  "Energy": "エネルギー",
  "Financials": "金融",
  "Health Care": "ヘルスケア",
  "Industrials": "資本財",
  "Information Technology": "情報技術",
  "Materials": "素材",
  "Real Estate": "不動産",
  "Utilities": "公益事業"
};

// Group by Sector
const stocksBySector = stocks.reduce((acc, stock) => {
  const sector = stock['GICS Sector'] || 'Unknown';
  if (!acc[sector]) {
    acc[sector] = [];
  }
  acc[sector].push(stock);
  return acc;
}, {} as Record<string, Stock[]>);

// Sort Sectors
const sortedSectors = Object.keys(stocksBySector).sort();

// Sort stocks within each sector
sortedSectors.forEach(sector => {
    stocksBySector[sector].sort((a: Stock, b: Stock) => a.Symbol_YF.localeCompare(b.Symbol_YF));
});

const formatChange = (change?: number) => {
  if (change === undefined || change === null) return null;
  const val = (change * 100).toFixed(2);
  const color = change >= 0 ? "text-green-600 dark:text-green-400" : "text-red-600 dark:text-red-400";
  const prefix = change >= 0 ? "+" : "";
  return { val, color, prefix };
};

// Calculate Average S&P 500 Change
const validChanges = stocks
  .filter(s => s.Daily_Change !== undefined && s.Daily_Change !== null)
  .map(s => s.Daily_Change as number);
const averageChange = validChanges.length > 0 
  ? validChanges.reduce((a, b) => a + b, 0) / validChanges.length 
  : null;
const formattedAvgChange = formatChange(averageChange || undefined);

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero" class="pt-8 pb-6">
      <div class="flex justify-center mb-4">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400 border border-green-200 dark:border-green-800">
          <span class="relative flex h-2 w-2 mr-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          米国市場閉場後、全500銘柄を毎日自動更新中
        </span>
      </div>
      <h1 class="my-4 text-3xl font-bold sm:my-8 sm:text-6xl text-center tracking-tighter bg-clip-text text-transparent bg-gradient-to-r from-skin-accent to-green-500">
        アメリカ株インサイト：<br class="sm:hidden" />S&P500銘柄深堀り
      </h1>

      {formattedAvgChange && (
        <div class="flex flex-col items-center justify-center mb-8">
          <div class={`inline-flex items-baseline px-8 py-3 rounded-2xl bg-skin-card border-2 ${formattedAvgChange.prefix === '+' ? 'border-green-500/30' : 'border-red-500/30'} shadow-md transform hover:scale-105 transition-transform`}>
            <span class="text-xs font-bold opacity-60 mr-4 uppercase tracking-[0.2em] border-r pr-4 border-skin-line">S&P 500 Market Avg</span>
            <span class={`text-4xl font-mono font-black ${formattedAvgChange.color} drop-shadow-sm`}>
              {formattedAvgChange.prefix === '+' ? '▲' : '▼'} {formattedAvgChange.val}%
            </span>
          </div>
        </div>
      )}

      <p class="mb-10 mt-4 text-center opacity-90 max-w-3xl mx-auto px-4 text-lg sm:text-xl leading-relaxed font-medium">
        市場が閉まるたび、全500銘柄のファンダメンタルズを全自動で解析。<br class="hidden sm:block" />
      </p>
    </section>

    <!-- Daily Rankings Section -->
    <section class="mb-12 max-w-app mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Gainers (Top 5) -->
        <div class="bg-skin-card p-6 rounded-xl border border-green-200 dark:border-green-900/50 shadow-sm">
          <h3 class="text-lg font-bold mb-4 flex items-center text-green-700 dark:text-green-400">
            <span class="mr-2 text-xl">📈</span> 今日の値上がり上位
          </h3>
          <div class="space-y-3">
            {[...stocks]
              .filter(s => s.Daily_Change !== undefined && s.Daily_Change !== null)
              .sort((a, b) => (b.Daily_Change || 0) - (a.Daily_Change || 0))
              .slice(0, 5)
              .map((stock) => {
                const change = formatChange(stock.Daily_Change);
                return (
                  <a href={`${base}report/${stock.Symbol_YF}/`} class="flex items-center justify-between p-2 hover:bg-green-50 dark:hover:bg-green-900/20 rounded transition-colors group">
                    <div class="flex items-center">
                      <span class="font-bold text-skin-accent w-16">{stock.Symbol_YF}</span>
                      {isRecentEarnings(stock) && (
                        <span class="mr-2 px-1 py-0.5 text-[10px] font-bold bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300 border border-amber-200 dark:border-amber-800 rounded leading-none uppercase tracking-tighter shadow-sm animate-pulse whitespace-nowrap">
                          決算
                        </span>
                      )}
                      <span class="text-sm opacity-80 truncate max-w-[120px] sm:max-w-[180px]">{stock.Security_JA || stock.Security}</span>
                    </div>
                    {change && (
                      <span class={`font-mono font-bold ${change.color}`}>
                        {change.prefix}{change.val}%
                      </span>
                    )}
                  </a>
                );
              })
            }
          </div>
        </div>

        <!-- Losers (Bottom 5) -->
        <div class="bg-skin-card p-6 rounded-xl border border-red-200 dark:border-red-900/50 shadow-sm">
          <h3 class="text-lg font-bold mb-4 flex items-center text-red-700 dark:text-red-400">
            <span class="mr-2 text-xl">📉</span> 今日の値下がり上位
          </h3>
          <div class="space-y-3">
            {[...stocks]
              .filter(s => s.Daily_Change !== undefined && s.Daily_Change !== null)
              .sort((a, b) => (a.Daily_Change || 0) - (b.Daily_Change || 0))
              .slice(0, 5)
              .map((stock) => {
                const change = formatChange(stock.Daily_Change);
                return (
                  <a href={`${base}report/${stock.Symbol_YF}/`} class="flex items-center justify-between p-2 hover:bg-red-50 dark:hover:bg-red-900/20 rounded transition-colors group">
                    <div class="flex items-center">
                      <span class="font-bold text-skin-accent w-16">{stock.Symbol_YF}</span>
                      {isRecentEarnings(stock) && (
                        <span class="mr-2 px-1 py-0.5 text-[10px] font-bold bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300 border border-amber-200 dark:border-amber-800 rounded leading-none uppercase tracking-tighter shadow-sm animate-pulse whitespace-nowrap">
                          決算
                        </span>
                      )}
                      <span class="text-sm opacity-80 truncate max-w-[120px] sm:max-w-[180px]">{stock.Security_JA || stock.Security}</span>
                    </div>
                    {change && (
                      <span class={`font-mono font-bold ${change.color}`}>
                        {change.prefix}{change.val}%
                      </span>
                    )}
                  </a>
                );
              })
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Sector Tags -->
    <section class="mb-10 max-w-app mx-auto px-4">
      <div class="flex flex-wrap justify-center gap-2">
        {sortedSectors.map((sector) => (
          <a 
            href={`#${sector}`}
            class="px-3 py-1 bg-skin-card border border-skin-line rounded-full text-sm hover:text-skin-accent hover:border-skin-accent transition-colors"
          >
            {sectorTranslations[sector] || sector}
          </a>
        ))}
      </div>
    </section>

    <section class="mb-12 max-w-app mx-auto px-4">
      {sortedSectors.map((sector) => (
        <div class="mb-12" id={sector}>
          <h2 class="text-2xl font-bold mb-6 border-l-4 border-skin-accent pl-4 flex items-baseline flex-wrap">
            <span class="mr-4">{sectorTranslations[sector] || '未分類'}</span>
            <span class="text-base font-normal opacity-70">{sector}</span>
          </h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
            {stocksBySector[sector].map((stock) => {
              const change = formatChange(stock.Daily_Change);
              return (
                <a 
                  href={`${base}report/${stock.Symbol_YF}/`} 
                  class="group block p-4 border border-skin-line rounded-lg hover:border-skin-accent hover:shadow-lg transition-all bg-skin-card relative overflow-hidden"
                >
                  {isRecentEarnings(stock) && (
                    <div class="absolute top-0 right-0 bg-amber-500 text-white text-[8px] font-black px-1.5 py-0.5 rounded-bl-lg uppercase tracking-tighter animate-pulse shadow-sm">
                      決算
                    </div>
                  )}
                  <div class="flex justify-between items-start mb-1">
                    <div class="text-lg font-bold text-skin-accent group-hover:underline decoration-dashed underline-offset-4">{stock.Symbol_YF}</div>
                    {change && (
                      <div class={`text-xs font-bold ${change.color} pt-1`}>
                        {change.prefix}{change.val}%
                      </div>
                    )}
                  </div>
                  <div class="text-sm opacity-90 truncate" title={stock.Security_JA || stock.Security}>{stock.Security_JA || stock.Security}</div>
                </a>
              );
            })}
          </div>
        </div>
      ))}
    </section>

    <!-- トップに戻るボタン -->
    <div class="mt-12 mb-20 text-center">
      <a href="#" class="px-6 py-2 bg-skin-card border border-skin-line rounded-full text-sm font-bold hover:text-skin-accent hover:border-skin-accent transition-all inline-flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z" clip-rule="evenodd" />
        </svg>
        ページトップへ戻る
      </a>
    </div>
  </main>
  <Footer />
</Layout>
