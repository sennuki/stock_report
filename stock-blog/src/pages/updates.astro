---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import stocks from "@/data/stocks.json";
import { loadTranscriptIndex } from "@/utils/transcripts";
import { loadChangeHistory } from "@/utils/change-history";
import { env } from "cloudflare:workers";

// R2 から実行時にデータを読むため SSR で動かす。
export const prerender = false;

const title = "更新履歴｜新規レポート・決算トランスクリプトの追加状況";
const description =
  "S&P 500/400/600 の構成銘柄入れ替えによる新規レポートの追加や、決算説明会トランスクリプトの追加など、サイトの更新を新しい順にまとめています。";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const baseNoSlash = base.replace(/\/$/, "");

// symbol -> 表示名 (日本語名があれば優先)
const nameBySymbol = new Map<string, string>();
for (const s of stocks as any[]) {
  const sym = s.Symbol_YF || s.Symbol;
  if (sym) nameBySymbol.set(sym, s.Security_JA || s.Security || sym);
}

interface UpdateItem {
  date: string;
  kind: "transcript" | "index_added" | "index_removed";
  label: string;
  text: string;
  href?: string;
}

const items: UpdateItem[] = [];

// 1) 指数構成銘柄の入れ替え
const changes = await loadChangeHistory(env, Astro.url);
for (const c of changes) {
  if (!c?.date || !c?.symbol) continue;
  const name = c.security || nameBySymbol.get(c.symbol) || c.symbol;
  if (c.type === "index_added") {
    items.push({
      date: c.date,
      kind: "index_added",
      label: "新規レポート",
      text: `${name}（${c.symbol}）が ${c.index} に採用され、レポートを追加しました。`,
      href: `${baseNoSlash}/report/${c.symbol}`,
    });
  } else if (c.type === "index_removed") {
    items.push({
      date: c.date,
      kind: "index_removed",
      label: "指数除外",
      text: `${name}（${c.symbol}）が ${c.index} の構成銘柄から除外されました。`,
    });
  }
}

// 2) 決算説明会トランスクリプト
const transcriptIndex = await loadTranscriptIndex(env, Astro.url);
for (const [symbol, entries] of Object.entries(transcriptIndex)) {
  const name = nameBySymbol.get(symbol) || symbol;
  for (const e of entries || []) {
    if (!e?.generated) continue;
    items.push({
      date: e.generated,
      kind: "transcript",
      label: "決算トランスクリプト",
      text: `${name}（${symbol}）の ${e.period} 決算説明会トランスクリプトを追加しました。`,
      href: `${baseNoSlash}/report/${symbol}/transcript/${e.period}`,
    });
  }
}

// 新しい順にソートし、表示件数を絞る。
items.sort((a, b) => (a.date < b.date ? 1 : a.date > b.date ? -1 : 0));
const display = items.slice(0, 120);

// 日付ごとにグループ化 (display は既に降順なので挿入順が保たれる)。
const byDate = new Map<string, UpdateItem[]>();
for (const it of display) {
  if (!byDate.has(it.date)) byDate.set(it.date, []);
  byDate.get(it.date)!.push(it);
}

const badgeClass = (kind: UpdateItem["kind"]) =>
  kind === "transcript"
    ? "bg-skin-accent/10 text-skin-accent"
    : kind === "index_added"
      ? "bg-green-600/10 text-green-600"
      : "bg-red-600/10 text-red-600";
---

<Layout title={title} description={description}>
  <Header />
  <main id="main-content" class="w-full px-4 py-8 max-w-app mx-auto">
    <Breadcrumbs
      items={[{ name: "トップ", href: "/" }, { name: "更新履歴" }]}
    />
    <h1 class="text-3xl font-bold mb-2">更新履歴</h1>
    <p class="opacity-70 mb-8 text-sm leading-relaxed">
      S&P 500/400/600 の構成銘柄入れ替えによる新規レポートの追加や、決算説明会トランスクリプトの追加など、サイトの更新を新しい順にまとめています。
    </p>

    {
      display.length === 0 && (
        <p class="opacity-70">まだ更新履歴がありません。</p>
      )
    }

    {
      [...byDate.entries()].map(([date, group]) => (
        <section class="mb-8">
          <h2 class="text-lg font-bold mb-3 border-b pb-2">{date}</h2>
          <ul class="space-y-3">
            {group.map(it => (
              <li class="bg-skin-card p-4 rounded-lg border border-skin-line">
                <span
                  class:list={[
                    "inline-block text-xs font-bold px-2 py-0.5 rounded mb-1",
                    badgeClass(it.kind),
                  ]}
                >
                  {it.label}
                </span>
                <p class="text-sm leading-relaxed">
                  {it.href ? (
                    <a
                      href={it.href}
                      class="text-skin-accent hover:underline"
                    >
                      {it.text}
                    </a>
                  ) : (
                    it.text
                  )}
                </p>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </main>
  <Footer />
</Layout>
