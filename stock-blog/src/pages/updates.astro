---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import stocks from "@/data/stocks.json";
import { loadTranscriptIndex } from "@/utils/transcripts";
import { loadChangeHistory } from "@/utils/change-history";
import { env } from "cloudflare:workers";

// R2 から実行時にデータを読むため SSR で動かす。
export const prerender = false;

// 決算トランスクリプトのブロックに表示する日数 (新しい順)。
const TRANSCRIPT_DAYS = 30;

const title = "更新履歴｜新規レポート・決算トランスクリプトの追加状況";
const description =
  "S&P 500/400/600 の構成銘柄入れ替えによる新規レポートの追加や、決算説明会トランスクリプトの追加など、サイトの更新を新しい順にまとめています。";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const baseNoSlash = base.replace(/\/$/, "");

// symbol -> 表示名 (日本語名があれば優先)
const nameBySymbol = new Map<string, string>();
const indexBySymbol = new Map<string, string>();
for (const s of stocks as any[]) {
  const sym = s.Symbol_YF || s.Symbol;
  if (sym) {
    nameBySymbol.set(sym, s.Security_JA || s.Security || sym);
    if (s.Index) indexBySymbol.set(sym, s.Index);
  }
}

interface IndexItem {
  date: string;
  kind: "index_added" | "index_removed" | "ticker_changed";
  label: string;
  text: string;
  href?: string;
}

interface TranscriptItem {
  symbol: string;
  name: string;
  /** "2026 Q1" 形式 (表示用)。 */
  period: string;
  generated: string;
  href: string;
  index: string;
}

// 1) 指数構成銘柄の入れ替え
const indexItems: IndexItem[] = [];
const changes = await loadChangeHistory(env, Astro.url);

// 同日・同指数で security 名が同じ added+removed ペア = ティッカー変更として扱う
const addedBySecurity = new Map<string, (typeof changes)[0]>();
const removedBySecurity = new Map<string, (typeof changes)[0]>();
for (const c of changes) {
  if (!c?.date || !c?.symbol || !c?.security) continue;
  const key = `${c.date}|${c.security}|${c.index}`;
  if (c.type === "index_added") addedBySecurity.set(key, c);
  else if (c.type === "index_removed") removedBySecurity.set(key, c);
}
const tickerChangedKeys = new Set<string>(
  [...addedBySecurity.keys()].filter(k => removedBySecurity.has(k))
);

for (const c of changes) {
  if (!c?.date || !c?.symbol) continue;
  const name = c.security || nameBySymbol.get(c.symbol) || c.symbol;
  const key = `${c.date}|${c.security}|${c.index}`;
  if (c.type === "index_added") {
    if (tickerChangedKeys.has(key)) {
      // ティッカー変更: removed 側の旧シンボルと合わせて1件にまとめる
      const oldEvent = removedBySecurity.get(key)!;
      indexItems.push({
        date: c.date,
        kind: "ticker_changed",
        label: "ティッカー変更",
        text: `${name} のティッカーが ${oldEvent.symbol} から ${c.symbol} に変更されました（${c.index}）。`,
        href: `${baseNoSlash}/report/${c.symbol}`,
      });
    } else {
      indexItems.push({
        date: c.date,
        kind: "index_added",
        label: "新規レポート",
        text: `${name}（${c.symbol}）が ${c.index} に採用され、レポートを追加しました。`,
        href: `${baseNoSlash}/report/${c.symbol}`,
      });
    }
  } else if (c.type === "index_removed") {
    if (tickerChangedKeys.has(key)) continue; // added 側でまとめ済み
    indexItems.push({
      date: c.date,
      kind: "index_removed",
      label: "指数除外",
      text: `${name}（${c.symbol}）が ${c.index} の構成銘柄から除外されました。`,
    });
  }
}
indexItems.sort((a, b) => (a.date < b.date ? 1 : a.date > b.date ? -1 : 0));
const indexDisplay = indexItems.slice(0, 120);

// 日付ごとにグループ化 (indexDisplay は降順なので挿入順が保たれる)。
const indexByDate = new Map<string, IndexItem[]>();
for (const it of indexDisplay) {
  if (!indexByDate.has(it.date)) indexByDate.set(it.date, []);
  indexByDate.get(it.date)!.push(it);
}

// 2) 決算説明会トランスクリプト: 日付ごとにグループ化して指数変更と同じ枠の下に並べる。
const transcripts: TranscriptItem[] = [];
const transcriptIndex = await loadTranscriptIndex(env, Astro.url);
for (const [symbol, entries] of Object.entries(transcriptIndex)) {
  const name = nameBySymbol.get(symbol) || symbol;
  for (const e of entries || []) {
    if (!e?.generated || !e?.period) continue;
    transcripts.push({
      symbol,
      name,
      period: String(e.period).replace("-", " "),
      generated: e.generated,
      href: `${baseNoSlash}/report/${symbol}/transcript/${e.period}`,
      index: indexBySymbol.get(symbol) || "",
    });
  }
}
transcripts.sort((a, b) =>
  a.generated < b.generated ? 1 : a.generated > b.generated ? -1 : 0
);
const cutoffDate = new Date();
cutoffDate.setDate(cutoffDate.getDate() - TRANSCRIPT_DAYS);
const cutoffStr = cutoffDate.toISOString().slice(0, 10);
const recentTranscripts = transcripts.filter(t => t.generated >= cutoffStr);

const transcriptsByDate = new Map<string, TranscriptItem[]>();
for (const t of recentTranscripts) {
  const date = t.generated.slice(0, 10); // YYYY-MM-DD
  if (!transcriptsByDate.has(date)) transcriptsByDate.set(date, []);
  transcriptsByDate.get(date)!.push(t);
}

// 両方の更新タイプから日付を集めて降順ソート
const allDates = [...new Set<string>([
  ...indexByDate.keys(),
  ...transcriptsByDate.keys(),
])].sort((a, b) => (a < b ? 1 : a > b ? -1 : 0));

const badgeClass = (kind: IndexItem["kind"]) =>
  kind === "index_added"
    ? "bg-green-600/10 text-green-600"
    : kind === "ticker_changed"
    ? "bg-blue-600/10 text-blue-600"
    : "bg-red-600/10 text-red-600";
---

<Layout title={title} description={description}>
  <Header />
  <main id="main-content" class="w-full px-4 py-8 max-w-app mx-auto">
    <Breadcrumbs
      items={[{ name: "トップ", href: "/" }, { name: "更新履歴" }]}
    />
    <h1 class="text-3xl font-bold mb-2">更新履歴</h1>
    <p class="opacity-70 mb-8 text-sm leading-relaxed">
      S&P 500/400/600 の構成銘柄入れ替えによる新規レポートの追加や、決算説明会トランスクリプトの追加など、サイトの更新をまとめています。
    </p>

    {
      allDates.length === 0 && (
        <p class="opacity-70">まだ更新履歴がありません。</p>
      )
    }

    {/* 日付ごとに指数変更と決算トランスクリプトをまとめて表示 */}
    {
      allDates.map(date => {
        const indexGroup = indexByDate.get(date) ?? [];
        const transcriptGroup = transcriptsByDate.get(date) ?? [];
        return (
          <section class="mb-8">
            <h2 class="text-lg font-bold mb-3 border-b pb-2">{date}</h2>
            <ul class="space-y-3">
              {indexGroup.map(it => (
                <li class="bg-skin-card p-4 rounded-lg border border-skin-line">
                  <span
                    class:list={[
                      "inline-block text-xs font-bold px-2 py-0.5 rounded mb-1",
                      badgeClass(it.kind),
                    ]}
                  >
                    {it.label}
                  </span>
                  <p class="text-sm leading-relaxed">
                    {it.href ? (
                      <a
                        href={it.href}
                        class="text-skin-accent hover:underline"
                      >
                        {it.text}
                      </a>
                    ) : (
                      it.text
                    )}
                  </p>
                </li>
              ))}
              {transcriptGroup.length > 0 && (() => {
                const SP500 = transcriptGroup.filter(t => t.index === "S&P 500");
                const SP400 = transcriptGroup.filter(t => t.index === "S&P 400");
                const SP600 = transcriptGroup.filter(t => t.index === "S&P 600");
                const OTHER = transcriptGroup.filter(t => !["S&P 500","S&P 400","S&P 600"].includes(t.index));
                const groups: { label: string; items: TranscriptItem[] }[] = [
                  { label: "S&P 500", items: SP500 },
                  { label: "S&P 400", items: SP400 },
                  { label: "S&P 600", items: SP600 },
                  { label: "その他", items: OTHER },
                ].filter(g => g.items.length > 0);
                return (
                  <li class="bg-skin-card p-4 rounded-lg border border-skin-line">
                    <span class="inline-block text-xs font-bold px-2 py-0.5 rounded mb-2 bg-skin-accent/10 text-skin-accent">
                      決算トランスクリプト
                    </span>
                    <p class="text-sm leading-relaxed mb-3">
                      決算説明会スクリプトを更新しました。
                    </p>
                    {groups.map(g => (
                      <div class="mb-3">
                        <p class="text-xs font-bold text-gray-500 mb-1">{g.label}</p>
                        <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-4 gap-y-1">
                          {g.items.map(t => (
                            <li class="text-sm truncate">
                              <a
                                href={t.href}
                                class="text-skin-accent hover:underline"
                              >
                                {t.name}（{t.symbol}）{t.period}
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    ))}
                  </li>
                );
              })()}
            </ul>
          </section>
        );
      })
    }
  </main>
  <Footer />
</Layout>
