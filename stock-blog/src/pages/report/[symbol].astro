---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import stocks from "@/data/stocks.json";
import ChartJs from "@/components/report/ChartJs.astro";
import TradingViewWidget from "@/components/report/TradingViewWidget.astro";
import PeerLinks from "@/components/report/PeerLinks.astro";
import EarningsHighlights from "@/components/report/EarningsHighlights.astro";
import JapanBrokers from "@/components/report/JapanBrokers.astro";

export async function getStaticPaths() {
  // Use stocks.json as the source of truth for symbols
  return (stocks as any[]).map((stock: any) => ({
    params: { symbol: stock.Symbol_YF },
  }));
}

const { symbol } = Astro.params;

let reportData: any = null;
let lastUpdated: string = "";

try {
  const response = await fetch(`${Astro.url.origin}/reports/${symbol}.json`);
  if (response.ok) {
    reportData = await response.json();
    lastUpdated = new Intl.DateTimeFormat("ja-JP", {
      year: "numeric",
      month: "long",
      day: "numeric",
    }).format(new Date());
  }
} catch (e) {
  if (import.meta.env.DEV) console.error(`Error loading report for ${symbol}:`, e);
  reportData = null;
}

const stockInfo = (stocks as any[]).find((s: any) => s.Symbol_YF === symbol);
const displaySecurity = stockInfo?.Security_JA || stockInfo?.Security || '';
const title = `${symbol} (${displaySecurity}) 銘柄分析：株価・PER・配当利回り・ファンダメンタル分析`;
const description = `${symbol} (${displaySecurity}) の最新株価、PER、配当利回り、財務推移などのファンダメンタルデータを網羅。投資判断に役立つ分析レポートを定期的に更新しています。`;

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

// Helper to translate grades to "Japanese (English)"
const translateGrade = (grade: string) => {
  if (!grade) return "---";
  const g = grade.toLowerCase();
  if (g.includes('strong buy')) return `強気買い (${grade})`;
  if (g.includes('buy') || g.includes('outperform') || g.includes('overweight')) return `買い (${grade})`;
  if (g.includes('hold') || g.includes('neutral') || g.includes('equal-weight') || g.includes('market perform')) return `中立 (${grade})`;
  if (g.includes('sell') || g.includes('underperform') || g.includes('underweight')) return `売り (${grade})`;
  if (g.includes('strong sell')) return `強い売り (${grade})`;
  return grade;
};

// Calculate Analyst Summary in frontmatter to avoid template parsing issues with "<"
let analystSummary = null;
if (reportData?.analyst_ratings) {
  const r = reportData.analyst_ratings;
  const total = (r.strongBuy || 0) + (r.buy || 0) + (r.hold || 0) + (r.sell || 0) + (r.strongSell || 0);
  const score = total > 0 
    ? ((r.strongBuy || 0) * 1 + (r.buy || 0) * 2 + (r.hold || 0) * 3 + (r.sell || 0) * 4 + (r.strongSell || 0) * 5) / total 
    : 0;
  
  let assessment = "不明";
  let assessmentColor = "text-gray-500";
  if (score > 0 && score <= 1.5) { assessment = "強気買い (Strong Buy)"; assessmentColor = "text-green-600"; }
  else if (score > 1.5 && score <= 2.5) { assessment = "買い (Buy)"; assessmentColor = "text-green-500"; }
  else if (score > 2.5 && score <= 3.5) { assessment = "中立 (Hold)"; assessmentColor = "text-gray-500"; }
  else if (score > 3.5 && score <= 4.5) { assessment = "売り (Sell)"; assessmentColor = "text-red-500"; }
  else if (score > 4.5) { assessment = "強い売り (Strong Sell)"; assessmentColor = "text-red-700"; }

  analystSummary = { 
    total, 
    score, 
    assessment, 
    assessmentColor, 
    ratings: r,
    targetHigh: r.targetHighPrice,
    targetLow: r.targetLowPrice,
    targetMean: r.targetMeanPrice,
    targetMedian: r.targetMedianPrice,
    currentPrice: r.currentPrice,
    opinions: r.numberOfAnalystOpinions
  };
}
---

<Layout title={title} description={description} ogImage={`${base}og.png`}>
  <Header />
  
  <main id="main-content" class="w-full px-4 py-8 max-w-app mx-auto">
    <div class="mb-6">
       <a href={base} class="text-skin-accent hover:underline inline-flex items-center">
         <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
         </svg>
         銘柄一覧に戻る
       </a>
    </div>

    {!reportData ? (
        <div class="report-content bg-skin-card p-10 rounded-lg border border-skin-line shadow-sm text-center">
          <p class="text-xl">レポートが見つかりません: {symbol}</p>
          <p class="mt-4 text-gray-500">データ生成プロセスを実行してください。</p>
        </div>
    ) : (
      <div class="report-content bg-skin-card p-4 sm:p-8 rounded-lg border border-skin-line shadow-sm" data-pagefind-body>
        <h1 class="text-3xl font-bold mb-2" data-pagefind-meta="title">銘柄分析レポート: {reportData.symbol} ({reportData.security_ja || reportData.security})</h1>
        {lastUpdated && (
          <div class="flex items-center text-sm text-gray-500 mb-6 bg-skin-fill/30 px-3 py-1.5 rounded-md border border-skin-line w-fit">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 text-skin-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>最終更新日: {lastUpdated} <span class="mx-2 text-skin-line">|</span> 米国市場閉場後、全銘柄を毎日自動更新</span>
          </div>
        )}

            <TradingViewWidget symbol={reportData.full_symbol} type="symbol-info" />

        <hr class="my-8 border-skin-line" />

        <nav class="toc bg-skin-fill/50 p-6 rounded-lg border border-skin-line mb-10">
            <h3 class="text-lg font-bold mb-4">目次</h3>
            <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-2 list-disc pl-5">
                <li><a href="#stock-chart" class="text-skin-accent hover:underline">{symbol}の株価推移・概要</a></li>
                <li><a href="#risk-return" class="text-skin-accent hover:underline">{symbol}のリスク・リターン分析</a></li>
                <li><a href="#peers" class="text-skin-accent hover:underline">{symbol}の同業種・競合</a></li>
                <li><a href="#sector-peers" class="text-skin-accent hover:underline">{symbol}の同セクター他社</a></li>
                <li><a href="#performance" class="text-skin-accent hover:underline">{symbol}のパフォーマンス比較</a></li>
                <li><a href="#earnings-highlights" class="text-skin-accent hover:underline">{symbol}の直近決算・財務ハイライト</a></li>
                <li><a href="#next-earnings" class="text-skin-accent hover:underline">{symbol}の来期業績予想</a></li>
                <li><a href="#revenue-by-segment" class="text-skin-accent hover:underline">{symbol}のセグメント収益</a></li>
                <li><a href="#revenue-by-geography" class="text-skin-accent hover:underline">{symbol}の地域別収益</a></li>
                <li><a href="#fundamentals" class="text-skin-accent hover:underline">{symbol}のファンダメンタルズ分析 (概要)</a></li>
                <li><a href="#fundamentals-detail" class="text-skin-accent hover:underline">{symbol}の財務データ推移 (詳細)</a></li>
                <li><a href="#analyst-ratings" class="text-skin-accent hover:underline">{symbol}のアナリスト評価 (直近)</a></li>
                <li><a href="#dcf-valuation" class="text-skin-accent hover:underline">{symbol}のDCF理論株価分析</a></li>
                <li><a href="#japan-brokers" class="text-skin-accent hover:underline">日本の証券会社での取り扱い</a></li>
            </ul>
        </nav>

        <section id="stock-chart">
          <h2 class="text-2xl font-bold mb-4 border-b pb-2 flex items-center gap-2">
            <span class="material-symbols-outlined text-skin-accent" aria-hidden="true">overview</span>
            {symbol}の株価推移・概要
          </h2>

          {reportData.movement_reason && (
            <div class="mb-8 p-6 bg-skin-accent/5 rounded-lg border-l-4 border-skin-accent shadow-sm leading-relaxed">
              <h3 class="text-lg font-bold mb-3 flex items-center gap-2 text-skin-accent">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                </svg>
                直近の株価変動理由 ({reportData.movement_reason.date})
              </h3>
              <div class="flex items-center gap-4 mb-3">
                <span class={`text-2xl font-black ${reportData.movement_reason.change_pct >= 0 ? 'text-green-600' : 'text-red-600'}`}>
                  {reportData.movement_reason.change_pct >= 0 ? '+' : ''}{(reportData.movement_reason.change_pct * 100).toFixed(2)}%
                </span>
                <span class="text-sm opacity-60">S&P 500 変動率上位銘柄</span>
              </div>
              <p class="text-skin-base whitespace-pre-wrap">{reportData.movement_reason.reason}</p>
              <p class="text-[10px] opacity-40 mt-4 text-right italic">※Gemini AI 3.1 Flash Lite による調査・分析 (Google Search 連携)</p>
            </div>
          )}
          
          {reportData.business_summary_ja && (
            <div class="mb-8 p-6 bg-skin-fill/20 rounded-lg border border-skin-line leading-relaxed">
              <h3 class="text-lg font-bold mb-3 flex items-center gap-2 text-skin-accent">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                会社概要 (AI翻訳)
              </h3>
              <p class="text-skin-base whitespace-pre-wrap">{reportData.business_summary_ja}</p>
            </div>
          )}

          <TradingViewWidget symbol={reportData.full_symbol} type="symbol-overview" height={650} />
        </section>

        <section id="risk-return" class="mt-12">
          <h2 class="text-2xl font-bold mb-4 border-b pb-2 flex items-center gap-2">
            <span class="material-symbols-outlined text-skin-accent" aria-hidden="true">scatter_plot</span>
            {symbol}のリスク・リターン分析
          </h2>
          <ChartJs chartData={reportData.charts.risk_return} id="chart-risk-return" height={550} />

          <div class="mt-6 space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="bg-skin-fill/20 p-4 rounded-lg border border-skin-line">
                <h3 class="font-bold text-sm mb-2 flex items-center gap-2 text-skin-accent">
                  <span class="w-2 h-2 bg-skin-accent rounded-full"></span>
                  X軸: リスク (年率ボラティリティ)
                </h3>
                <p class="text-xs opacity-80 leading-relaxed">
                  株価の変動の激しさ（ヒストリカル・ボラティリティ）を示します。この値が高いほど、価格の上下動が大きく、不確実性が高いことを意味します。
                </p>
              </div>
              <div class="bg-skin-fill/20 p-4 rounded-lg border border-skin-line">
                <h3 class="font-bold text-sm mb-2 flex items-center gap-2 text-skin-accent">
                  <span class="w-2 h-2 bg-skin-accent rounded-full"></span>
                  Y軸: リターン (年率換算利回り)
                </h3>
                <p class="text-xs opacity-80 leading-relaxed">
                  指定期間の累積リターンを1年あたりの利回りに換算した値です。配当を含まない価格変化ベースの平均的な成長力を示します。
                </p>
              </div>
            </div>

            <details class="group bg-skin-fill/10 border border-skin-line rounded-lg overflow-hidden">
              <summary class="flex items-center justify-between p-3 cursor-pointer hover:bg-skin-fill/20 transition-colors text-xs font-bold opacity-70">
                <span>算出ロジックの詳細 (Mathematical Definition)</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transform group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="p-4 border-t border-skin-line space-y-6 bg-skin-card/50 font-serif">
                <div>
                  <p class="text-xs font-bold mb-3 font-sans">■ X軸: リスク (Annualized Volatility)</p>
                  <div class="flex justify-center py-2">
                    <img src="https://latex.codecogs.com/svg.latex?%5Cdpi%7B130%7D%20%5Cbg%7Bwhite%7D%20Risk%20%3D%20%5Csigma_%7Bdaily%7D%20%5Ctimes%20%5Csqrt%7B252%7D" alt="Risk formula" class="dark:invert h-6" />
                  </div>
                  <div class="opacity-60 text-[10px] flex flex-wrap justify-center gap-x-4 gap-y-1 font-sans border-t border-skin-line/10 pt-2 text-center">
                    <span><strong>σ_daily</strong>:日次対数リターンの標準偏差</span>
                    <span><strong>252</strong>:年間営業日数</span>
                  </div>
                </div>
                <div class="pt-4 border-t border-skin-line/30">
                  <p class="text-xs font-bold mb-3 font-sans">■ Y軸: 年率リターン (Annualized Return)</p>
                  <div class="flex justify-center py-2">
                    <img src="https://latex.codecogs.com/svg.latex?%5Cdpi%7B130%7D%20%5Cbg%7Bwhite%7D%20Return%20%3D%20%281%20%2B%20R_%7Btotal%7D%20%29%5E%7B%5Cfrac%7B365%7D%7BD%7D%7D%20-%201" alt="Return formula" class="dark:invert h-8" />
                  </div>
                  <div class="opacity-60 text-[10px] flex flex-wrap justify-center gap-x-4 gap-y-1 font-sans border-t border-skin-line/10 pt-2 text-center">
                    <span><strong>R_total</strong>:期間累積収益率</span>
                    <span><strong>D</strong>:経過日数</span>
                  </div>
                </div>
              </div>
            </details>
          </div>
        </section>
        <section id="peers" class="mt-12">
          <PeerLinks title={`${symbol}の同業種・競合 (${reportData.sub_industry})`} peers={reportData.peers.sub_industry} icon="corporate_fare" />
        </section>

        <section id="sector-peers">
          <PeerLinks title={`${symbol}の同セクター他社 (${reportData.sector})`} peers={reportData.peers.sector} collapsible={true} icon="corporate_fare" />
        </section>

        <hr class="my-12 border-skin-line" />

        <section id="performance">
          <h2 class="text-2xl font-bold mb-4 border-b pb-2 flex items-center gap-2">
            <span class="material-symbols-outlined text-skin-accent" aria-hidden="true">ssid_chart</span>
            {symbol}のパフォーマンス比較
          </h2>
          {reportData.charts.performance ? (
            <ChartJs chartData={reportData.charts.performance} id="chart-performance" />
          ) : (
            <TradingViewWidget 
              symbol={reportData.full_symbol} 
              type="advanced-chart" 
              height={600} 
              compareSymbols={[
                { symbol: `AMEX:${reportData.sector_etf}`, position: "SameScale" },
                { symbol: "FRED:SP500", position: "SameScale" }
              ]}
            />
          )}
        </section>

        <EarningsHighlights
          symbol={symbol}
          highlights={reportData.highlights}
          earnings_surprise={reportData.earnings_surprise}
          next_earnings={reportData.next_earnings}
          consensus={reportData.consensus}
        />

        <section id="next-earnings" class="mt-12">
          <h2 class="text-2xl font-bold mb-6 border-b pb-2 flex items-center gap-2">
            <span class="material-symbols-outlined text-skin-accent" aria-hidden="true">trending_up</span>
            {symbol}の来期業績予想 (コンセンサス)
          </h2>
          
          {(reportData.next_earnings || reportData.consensus) ? (
            <div class="space-y-6">
              {reportData.next_earnings && (
                <div class="bg-skin-fill/20 p-6 sm:p-8 rounded-lg border border-skin-line shadow-sm flex flex-col md:flex-row justify-between items-center gap-8">
                  <div class="flex-grow">
                    <div class="flex items-center gap-3 mb-4">
                      <div class="p-3 bg-skin-accent/10 rounded-full text-skin-accent">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                      </div>
                      <div>
                        <h3 class="text-xl font-bold">次回決算発表予定</h3>
                        <p class="text-gray-500">{reportData.next_earnings.date} (予定)</p>
                      </div>
                    </div>
                    <p class="text-sm opacity-80 leading-relaxed">
                      市場アナリストによる次回の四半期決算予想（コンセンサス）です。実績がこの予想を上回る（ポジティブサプライズ）か、下回るかが、発表直後の株価に大きく影響します。
                    </p>
                  </div>

                  <div class="flex items-center gap-8 bg-skin-fill/30 p-6 rounded-xl border border-skin-line min-w-[280px] justify-center">
                    <div class="text-center">
                      <div class="text-xs opacity-60 uppercase tracking-wider mb-2">市場予想 (EPS)</div>
                      <div class="text-4xl font-black text-skin-accent">
                        {typeof reportData.next_earnings.estimate === 'number' ? `$${reportData.next_earnings.estimate.toFixed(2)}` : '---'}
                      </div>
                      {reportData.earnings_surprise && typeof reportData.next_earnings.estimate === 'number' && typeof reportData.earnings_surprise.actual === 'number' && (
                        <div class={`mt-3 inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold ${reportData.next_earnings.estimate > reportData.earnings_surprise.actual ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
                          {reportData.next_earnings.estimate > reportData.earnings_surprise.actual ? '↑ 前期比 増益予想' : '↓ 前期比 減益予想'}
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              )}

              {/* Detailed Consensus Grid */}
              {reportData.consensus && (
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  {/* EPS Consensus */}
                  <div class="bg-skin-fill/10 p-6 rounded-lg border border-skin-line">
                    <h4 class="font-bold mb-4 flex items-center gap-2">
                      <span class="material-symbols-outlined text-blue-500" aria-hidden="true">attach_money</span> 1株あたり利益 (EPS) 予想 [来期通期]
                    </h4>
                    <div class="space-y-4">
                      <div class="flex justify-between items-center py-2 border-b border-skin-line/30">
                        <span class="text-sm opacity-70">コンセンサス (平均)</span>
                        <span class="font-bold text-lg text-skin-accent">
                          {reportData.consensus.earnings?.["+1y"]?.avg ? `$${reportData.consensus.earnings["+1y"].avg.toFixed(2)}` : 
                           reportData.consensus.earnings?.["0y"]?.avg ? `$${reportData.consensus.earnings["0y"].avg.toFixed(2)} (今期)` : 
                           reportData.consensus.earnings?.["0q"]?.avg ? `$${reportData.consensus.earnings["0q"].avg.toFixed(2)} (四半期)` : '---'}
                        </span>
                      </div>
                      <div class="flex justify-between items-center py-2 border-b border-skin-line/30">
                        <span class="text-sm opacity-70">予想レンジ (Low - High)</span>
                        <span class="text-sm font-medium">
                          {reportData.consensus.earnings?.["+1y"]?.low ? `$${reportData.consensus.earnings["+1y"].low.toFixed(2)}` : 
                           reportData.consensus.earnings?.["0y"]?.low ? `$${reportData.consensus.earnings["0y"].low.toFixed(2)}` : '---'} - 
                          {reportData.consensus.earnings?.["+1y"]?.high ? `$${reportData.consensus.earnings["+1y"].high.toFixed(2)}` : 
                           reportData.consensus.earnings?.["0y"]?.high ? `$${reportData.consensus.earnings["0y"].high.toFixed(2)}` : '---'}
                        </span>
                      </div>
                      <div class="flex justify-between items-center py-2 border-b border-skin-line/30">
                        <span class="text-sm opacity-70">前年比成長率 (YoY)</span>
                        <span class={`font-bold ${(reportData.consensus.earnings?.["+1y"]?.growth || reportData.consensus.earnings?.["0y"]?.growth || 0) >= 0 ? 'text-green-600' : 'text-red-600'}`}>
                          {reportData.consensus.earnings?.["+1y"]?.growth ? `${(reportData.consensus.earnings["+1y"].growth * 100).toFixed(1)}%` : 
                           reportData.consensus.earnings?.["0y"]?.growth ? `${(reportData.consensus.earnings["0y"].growth * 100).toFixed(1)}%` : '---'}
                        </span>
                      </div>
                      <div class="flex justify-between items-center py-2">
                        <span class="text-sm opacity-70">アナリスト数</span>
                        <span class="text-sm">{reportData.consensus.earnings?.["+1y"]?.numberOfAnalysts || reportData.consensus.earnings?.["0y"]?.numberOfAnalysts || '---'}人</span>
                      </div>
                    </div>
                  </div>

                  {/* Revenue Consensus */}
                  <div class="bg-skin-fill/10 p-6 rounded-lg border border-skin-line">
                    <h4 class="font-bold mb-4 flex items-center gap-2">
                      <span class="material-symbols-outlined text-green-500" aria-hidden="true">money_bag</span> 売上高予想 [来期通期]
                    </h4>
                    <div class="space-y-4">
                      <div class="flex justify-between items-center py-2 border-b border-skin-line/30">
                        <span class="text-sm opacity-70">コンセンサス (平均)</span>
                        <span class="font-bold text-lg text-skin-accent">
                          {reportData.consensus.revenue?.["+1y"]?.avg ? `$${(reportData.consensus.revenue["+1y"].avg / 1e9).toFixed(2)}B` : 
                           reportData.consensus.revenue?.["0y"]?.avg ? `$${(reportData.consensus.revenue["0y"].avg / 1e9).toFixed(2)}B (今期)` : 
                           reportData.consensus.revenue?.["0q"]?.avg ? `$${(reportData.consensus.revenue["0q"].avg / 1e9).toFixed(2)}B (四半期)` : '---'}
                        </span>
                      </div>
