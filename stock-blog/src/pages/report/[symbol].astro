                <div class="flex gap-2 text-green-600"><span class="opacity-60 text-skin-base">+ 現金等:</span> <span class="font-bold">${(reportData.dcf_valuation.cash_value / 1e9).toFixed(2)}B</span></div>
                <div class="flex gap-2 text-red-600"><span class="opacity-60 text-skin-base">- 総負債:</span> <span class="font-bold">${(reportData.dcf_valuation.total_debt / 1e9).toFixed(2)}B</span></div>
                <div class="flex gap-2 border-l border-skin-line pl-6 ml-auto"><span class="opacity-60">株主価値:</span> <span class="font-bold text-skin-accent">${(reportData.dcf_valuation.equity_value / 1e9).toFixed(2)}B</span></div>
                <div class="flex gap-2"><span class="opacity-60">発行済株式数:</span> <span class="font-bold">{(reportData.dcf_valuation.shares / 1e6).toFixed(1)}M</span></div>
