                  </h3>
                  <div class="overflow-x-auto rounded-lg border border-skin-line">
                    <table class="min-w-full divide-y divide-skin-line text-xs">
                      <thead class="bg-skin-fill/20">
                        <tr>
                          <th class="px-3 py-3 text-left font-bold">年</th>
                          {reportData.dcf_valuation.projections.map((p: any) => (
                            <th class="px-3 py-3 text-right font-bold">{p.year}年目</th>
