---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import { SITE } from "@/config";
import stocks from "@/data/stocks.json";
import { loadTranscriptIndex, transcriptsForSymbol } from "@/utils/transcripts";
import fs from "node:fs";
import path from "node:path";
import { env } from "cloudflare:workers";
import ChartJs from "@/components/report/ChartJs.astro";
import TradingViewWidget from "@/components/report/TradingViewWidget.astro";
import PeerLinks from "@/components/report/PeerLinks.astro";
import ShareCard from "@/components/report/ShareCard.astro";
import TranscriptLinks from "@/components/report/TranscriptLinks.astro";
import AiPromptButton from "@/components/report/AiPromptButton.astro";

export const prerender = false;

const { symbol } = Astro.params;

let reportData: any = null;
let lastUpdated: string = "";

// データ取得試行のデバッグ情報。reportData が null になる原因を切り分ける
// ためページ末尾に HTML コメントとして埋め込む。問題が解決したら削除する。
const _debug = {
  symbol,
  public_worker_api_url: (import.meta.env.PUBLIC_WORKER_API_URL as string | undefined) || null,
  paths: [] as Array<Record<string, any>>,
  result: "no-data",
};

// 1) 本番 (Cloudflare Worker / 自前ドメイン): R2 バインディングから直接読む。
//    S&P 400/600 のレポートは git にコミットされていないが、ワーカーが
//    R2 に書き込んだものを実行時に取得できる。
//    Astro v6 で Astro.locals.runtime.env は削除されたため、cloudflare:workers
//    の env のみ参照する。Cloudflare Pages では binding が無いので skip される。
{
  const p: Record<string, any> = { name: "r2_binding" };
  try {
    const bucket = (env as any)?.STOCK_DATA;
    p.has_cloudflare_workers_env = !!bucket;
    if (bucket && symbol) {
      const object = await bucket.get(`reports/${symbol}.json`);
      p.r2_object_found = !!object;
      if (object) {
        const raw = await object.text();
        const sanitized = raw
          .replace(/\bNaN\b/g, "null")
          .replace(/-?\bInfinity\b/g, "null");
        reportData = JSON.parse(sanitized);
        const uploaded = (object as any).uploaded;
        if (uploaded) {
          lastUpdated = new Intl.DateTimeFormat("ja-JP", {
            year: "numeric",
            month: "long",
            day: "numeric",
          }).format(new Date(uploaded));
        } else {
          lastUpdated = "R2取得";
        }
        _debug.result = "r2_binding";
      }
    }
  } catch (e: any) {
    p.error = String(e?.message || e);
    if (import.meta.env.DEV) console.error(`R2 fetch failed for ${symbol}:`, e);
  }
  _debug.paths.push(p);
}

// 2) Cloudflare Pages のプレビューデプロイなど R2 バインディングが
//    無い環境でも動くよう、Worker の HTTP API にフォールバックする。
if (!reportData && symbol) {
  const p: Record<string, any> = { name: "worker_http_api" };
  const apiBase = import.meta.env.PUBLIC_WORKER_API_URL as string | undefined;
  p.api_base = apiBase || null;
  if (apiBase) {
    const apiUrl = `${apiBase.replace(/\/$/, "")}/api/report/${encodeURIComponent(symbol)}`;
    p.api_url = apiUrl;
    try {
      const resp = await fetch(apiUrl);
      p.status = resp.status;
      if (resp.ok) {
        const raw = await resp.text();
        const sanitized = raw
          .replace(/\bNaN\b/g, "null")
          .replace(/-?\bInfinity\b/g, "null");
        reportData = JSON.parse(sanitized);
        const lastModified = resp.headers.get("last-modified");
        lastUpdated = lastModified
          ? new Intl.DateTimeFormat("ja-JP", {
              year: "numeric",
              month: "long",
              day: "numeric",
            }).format(new Date(lastModified))
          : "Worker API取得";
        _debug.result = "worker_http_api";
      }
    } catch (e: any) {
      p.error = String(e?.message || e);
      if (import.meta.env.DEV) console.error(`Worker API fetch failed for ${symbol}:`, e);
    }
  } else {
    p.skipped_reason = "PUBLIC_WORKER_API_URL is empty";
  }
  _debug.paths.push(p);
}

// 3) ローカル開発時のフォールバック: public/reports/{symbol}.json を読む。
//    Astro 6 + Cloudflare アダプターの開発環境 (workerd) では node:fs が制限されるため、
//    DEV モードかつ fs で見つからない場合は自身に fetch を試みる。
{
  const p: Record<string, any> = { name: "local_fs" };
  try {
    let raw: string | null = null;

    // 3-a) まずは node:fs を試す (環境によって動作する場合がある)
    if (fs && path) {
      const possibleRoots = [
        process.cwd(),
        path.join(process.cwd(), 'stock-blog'),
        '/home/linux/gemini/stock-blog',
      ];
      let jsonPath = "";
      for (const root of possibleRoots) {
        try {
          const testPath = path.resolve(root, "public", "reports", `${symbol}.json`);
          if (fs.existsSync(testPath)) {
            jsonPath = testPath;
            break;
          }
        } catch (e) {}
      }
      if (jsonPath) {
        p.found_path = jsonPath;
        const stats = fs.statSync(jsonPath);
        if (stats.size > 0) {
          raw = fs.readFileSync(jsonPath, "utf-8");
          lastUpdated = new Intl.DateTimeFormat("ja-JP", {
            year: "numeric", month: "long", day: "numeric"
          }).format(stats.mtime);
        }
      }
    }

    // 3-b) node:fs で取れなかった場合、DEV モードなら自分自身へ fetch を投げる
    if (!raw && import.meta.env.DEV && symbol) {
      p.dev_fetch_attempted = true;
      try {
        // Astro.url を利用してベースURLを特定
        const devUrl = new URL(`/reports/${symbol}.json`, Astro.url);
        p.dev_url = devUrl.toString();
        const resp = await fetch(devUrl);
        if (resp.ok) {
          raw = await resp.text();
          lastUpdated = "Local Dev Fetch";
          p.dev_fetch_success = true;
        }
      } catch (e: any) {
        p.dev_fetch_error = e.message;
      }
    }

    if (raw && !reportData) {
      const sanitized = raw
        .replace(/\bNaN\b/g, "null")
        .replace(/-?\bInfinity\b/g, "null");
      reportData = JSON.parse(sanitized);
      _debug.result = "local_fs";
    }
  } catch (e: any) {
    p.error = String(e?.message || e);
    if (import.meta.env.DEV) console.error(`Local JSON fallback failed for ${symbol}:`, e);
  }
  _debug.paths.push(p);
}

const stockInfo = (stocks as any[]).find((s: any) => s.Symbol_YF === symbol);
const displaySecurity = stockInfo?.Security_JA || stockInfo?.Security || '';

// 決算説明会トランスクリプト: 索引に登録があればこの銘柄ページからリンクする。
// 索引は generate_transcript_report.py が R2 を更新し、SSR 時に読み込む。
const transcriptIndex = await loadTranscriptIndex(env, Astro.url);
const transcripts = transcriptsForSymbol(transcriptIndex, symbol as string);
const englishName = stockInfo?.Security || '';
const sector = stockInfo?.["GICS Sector"] || '';
const stockIndex = stockInfo?.Index || '';
const indexSlug = stockIndex.replace(/[^A-Za-z0-9]/g, '-');
const sectorAnchor = (stockIndex && sector) ? `${indexSlug}-${sector}` : '';
const indexHref = stockIndex ? `/?idx=${encodeURIComponent(stockIndex)}` : '/';
const sectorHref = sectorAnchor ? `/?idx=${encodeURIComponent(stockIndex)}#${encodeURIComponent(sectorAnchor)}` : indexHref;
const title = `${symbol} (${displaySecurity}) 銘柄分析：株価・PER・配当利回り・ファンダメンタル分析`;

// Build a richer, data-driven meta description with real metrics
const fmt = (v: any, suffix = "") =>
  typeof v === "number" && isFinite(v) ? `${v.toFixed(2)}${suffix}` : null;
const fmtPct = (v: any) =>
  typeof v === "number" && isFinite(v) ? `${(v * 100).toFixed(1)}%` : null;
// 配当利回りは yfinance がパーセント単位で返す場合がある (0.36 = 0.36%)。
// 0.5 超なら明らかに % 単位なので ÷100 して小数に揃える。
const normDividendYield = (v: any) =>
  typeof v === "number" ? (v > 0.5 ? v / 100 : v) : v;

const h = reportData?.highlights ?? {};
const descParts: string[] = [
  `${symbol}${displaySecurity ? `（${displaySecurity}）` : ""}の銘柄分析レポート。`,
];
if (fmt(h.pe_forward)) descParts.push(`予想PER ${fmt(h.pe_forward, "倍")}`);
if (fmt(h.pe_ttm)) descParts.push(`実績PER ${fmt(h.pe_ttm, "倍")}`);
if (fmtPct(normDividendYield(h.dividend_yield))) descParts.push(`配当利回り ${fmtPct(normDividendYield(h.dividend_yield))}`);
if (fmtPct(h.revenue_growth)) descParts.push(`売上成長率 ${fmtPct(h.revenue_growth)}`);
if (fmtPct(h.roe)) descParts.push(`ROE ${fmtPct(h.roe)}`);
const metricsLine = descParts.length > 1 ? descParts.slice(1).join("・") + "。" : "";
const description = (reportData
  ? `${descParts[0]}${metricsLine}最新の財務ハイライト、アナリスト評価、DCF理論株価、競合比較を網羅。投資判断の参考に。`
  : `${symbol} (${displaySecurity}) の最新株価、PER、配当利回り、財務推移などのファンダメンタルデータを網羅。投資判断に役立つ分析レポートを定期的に更新しています。`
).slice(0, 158);

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

// Build structured data for SEO: BreadcrumbList + FinancialProduct
const siteUrl = SITE.website?.replace(/\/$/, "") || "";
const pageUrl = `${siteUrl}${base}report/${symbol}`;

const _bcItems: Array<{name: string; item: string}> = [
  { name: "ホーム", item: `${siteUrl}/` },
];
if (stockIndex) _bcItems.push({ name: stockIndex, item: `${siteUrl}${indexHref}` });
if (sector) _bcItems.push({ name: sector, item: `${siteUrl}${sectorHref}` });
_bcItems.push({ name: `${symbol} ${displaySecurity}`, item: pageUrl });
const breadcrumbList = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: _bcItems.map((it, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: it.name,
    item: it.item,
  })),
};

const currentPrice = reportData?.analyst_ratings?.currentPrice;
const financialProduct: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "FinancialProduct",
  name: `${englishName || displaySecurity || symbol} (${symbol})`,
  alternateName: displaySecurity || undefined,
  identifier: symbol,
  category: sector || undefined,
  url: pageUrl,
  description,
};
if (typeof currentPrice === "number" && isFinite(currentPrice)) {
  financialProduct.offers = {
    "@type": "Offer",
    price: currentPrice,
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
  };
}

const extraStructuredData = [breadcrumbList, financialProduct];

// Helper to translate grades to "Japanese (English)"
const translateGrade = (grade: string) => {
  if (!grade) return "---";
  const g = grade.toLowerCase();
  if (g.includes('strong buy')) return `強気買い (${grade})`;
  if (g.includes('buy') || g.includes('outperform') || g.includes('overweight')) return `買い (${grade})`;
  if (g.includes('hold') || g.includes('neutral') || g.includes('equal-weight') || g.includes('market perform')) return `中立 (${grade})`;
  if (g.includes('sell') || g.includes('underperform') || g.includes('underweight')) return `売り (${grade})`;
  if (g.includes('strong sell')) return `強い売り (${grade})`;
  return grade;
};

// Calculate Analyst Summary in frontmatter to avoid template parsing issues with "<"
let analystSummary = null;
if (reportData?.analyst_ratings) {
  const r = reportData.analyst_ratings;
  const total = (r.strongBuy || 0) + (r.buy || 0) + (r.hold || 0) + (r.sell || 0) + (r.strongSell || 0);
  const score = total > 0 
    ? ((r.strongBuy || 0) * 1 + (r.buy || 0) * 2 + (r.hold || 0) * 3 + (r.sell || 0) * 4 + (r.strongSell || 0) * 5) / total 
    : 0;
  
  let assessment = "不明";
  let assessmentColor = "text-gray-500";
  if (score > 0 && score <= 1.5) { assessment = "強気買い (Strong Buy)"; assessmentColor = "text-green-600"; }
  else if (score > 1.5 && score <= 2.5) { assessment = "買い (Buy)"; assessmentColor = "text-green-500"; }
  else if (score > 2.5 && score <= 3.5) { assessment = "中立 (Hold)"; assessmentColor = "text-gray-500"; }
  else if (score > 3.5 && score <= 4.5) { assessment = "売り (Sell)"; assessmentColor = "text-red-500"; }
  else if (score > 4.5) { assessment = "強い売り (Strong Sell)"; assessmentColor = "text-red-700"; }

  analystSummary = { 
    total, 
    score, 
    assessment, 
    assessmentColor, 
    ratings: r,
    targetHigh: r.targetHighPrice,
    targetLow: r.targetLowPrice,
    targetMean: r.targetMeanPrice,
    targetMedian: r.targetMedianPrice,
    currentPrice: r.currentPrice,
    opinions: r.numberOfAnalystOpinions
  };
}

// ランキング表示用ヘルパー (テンプレート内に TypeScript 型を書くと JSX 解析と
// 衝突するため frontmatter にまとめる)。
type RankUnit = "currency" | "percent" | "price" | "count" | "ratio";
type RankMetric = [string, string, RankUnit];
// 指標をジャンル別に整理 (1つのテーブル内でセクション分けして表示)
const RANK_GROUPS: Array<{ genre: string; keys: RankMetric[] }> = [
  { genre: "規模・財務基盤", keys: [
    ["market_cap",  "時価総額",   "currency"],
    ["revenue_ttm", "TTM 売上",   "currency"],
    ["total_cash",  "現金保有額", "currency"],
    ["employees",   "従業員数",   "count"],
  ]},
  { genre: "収益性", keys: [
    ["roe",              "ROE",        "percent"],
    ["roa",              "ROA",        "percent"],
    ["operating_margin", "営業利益率", "percent"],
    ["gross_margin",     "粗利率",     "percent"],
  ]},
  { genre: "成長性", keys: [
    ["revenue_cagr_3y", "売上 3Y CAGR", "percent"],
    ["eps_9y_cagr",     "EPS 9Y CAGR",  "percent"],
  ]},
  { genre: "バリュエーション", keys: [
    ["forward_pe", "PER (予想)", "ratio"],
    ["pbr",        "PBR",        "ratio"],
    ["psr",        "PSR",        "ratio"],
  ]},
  { genre: "配当", keys: [
    ["dividend_yield", "配当利回り",         "percent"],
    ["dividend_rate",  "1株あたり配当 (年)", "price"],
  ]},
  { genre: "生産性", keys: [
    ["revenue_per_employee", "売上 / 従業員",     "currency"],
    ["mcap_per_employee",    "時価総額 / 従業員", "currency"],
  ]},
  { genre: "株価・リスク", keys: [
    ["stock_price",        "株価",             "price"],
    ["range_position_52w", "52週レンジ内位置", "percent"],
    ["beta",               "ベータ",           "ratio"],
  ]},
];
function fmtRankValue(v: number | null | undefined, unit: RankUnit): string {
  if (v == null || !Number.isFinite(v)) return "---";
  if (unit === "currency") {
    const abs = Math.abs(v);
    if (abs >= 1e12) return `$${(v / 1e12).toFixed(2)}T`;
    if (abs >= 1e9)  return `$${(v / 1e9).toFixed(2)}B`;
    if (abs >= 1e6)  return `$${(v / 1e6).toFixed(2)}M`;
    if (abs >= 1e3)  return `$${(v / 1e3).toFixed(1)}K`;
    return `$${v.toFixed(0)}`;
  }
  if (unit === "percent") return `${(v * 100).toFixed(2)}%`;
  if (unit === "price") return `$${v.toFixed(2)}`;
  if (unit === "count") return v.toLocaleString();
  return v.toFixed(2);
}
type RankCell = { rank: number; total: number; percentile: number } | null;
function fmtRank(r: RankCell): { text: string; tier: string } | null {
  if (!r) return null;
  const topPct = Math.max(1, Math.ceil((r.rank / r.total) * 100));
  const tier = topPct <= 5 ? "top5" : topPct <= 10 ? "top10" : topPct <= 25 ? "top25" : "mid";
  return { text: `${r.rank}位 / ${r.total} (上位 ${topPct}%)`, tier };
}
function rankTierClass(tier: string): string {
  if (tier === "top5")  return "text-amber-600 dark:text-amber-400 font-bold";
  if (tier === "top10") return "text-green-700 dark:text-green-400 font-bold";
  if (tier === "top25") return "text-skin-base font-medium";
  return "opacity-70";
}
function rankingSlug(key: string): string {
  return key.replace(/_/g, '-');
}
---

<Layout title={title} description={description} extraStructuredData={extraStructuredData}>
  <Header />

  <main id="main-content" class="w-full px-4 py-8 max-w-app mx-auto">
    <Breadcrumbs items={[
      { name: "ホーム", href: "/" },
      ...(stockIndex ? [{ name: stockIndex, href: indexHref }] : []),
      ...(sector ? [{ name: sector, href: sectorHref }] : []),
      { name: symbol },
    ]} />
    <div class="mb-6">
       <a href={base} class="text-skin-accent hover:underline inline-flex items-center">
         <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
         </svg>
         銘柄一覧に戻る
       </a>
    </div>

    {!reportData ? (
        <div class="report-content bg-skin-card p-10 rounded-lg border border-skin-line shadow-sm text-center">
          <p class="text-xl">レポートが見つかりません: {symbol}</p>
          <p class="mt-4 text-gray-500">データ生成プロセスを実行してください。</p>
          <details class="mt-6 text-left text-sm">
            <summary class="cursor-pointer text-gray-500">デバッグ情報</summary>
            <pre class="mt-2 p-4 bg-gray-100 dark:bg-gray-800 rounded overflow-x-auto text-xs">{JSON.stringify(_debug, null, 2)}</pre>
          </details>
        </div>
    ) : (
      <div class="report-content bg-skin-card p-4 sm:p-8 rounded-lg border border-skin-line shadow-sm" data-pagefind-body>
        <h1 class="text-3xl font-bold mb-2 flex flex-wrap items-baseline gap-3" data-pagefind-meta="title">
          <span>銘柄分析レポート: {reportData.symbol} ({reportData.security_ja || reportData.security})</span>
          {stockInfo?.Index && (
            <a
              href={`${base}?idx=${encodeURIComponent(stockInfo.Index)}`}
              class="text-xs font-bold px-2 py-1 rounded border border-skin-accent/40 text-skin-accent hover:bg-skin-accent/10 transition-colors no-underline"
              aria-label={`${stockInfo.Index} 構成銘柄の一覧へ`}
            >
              {stockInfo.Index}
            </a>
          )}
        </h1>
        {lastUpdated && (
          <div class="flex items-center text-sm text-gray-500 mb-6 bg-skin-fill/30 px-3 py-1.5 rounded-md border border-skin-line w-fit">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 text-skin-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>最終更新日: {lastUpdated} <span class="mx-2 text-skin-line">|</span> 米国市場閉場後、全銘柄を毎日自動更新</span>
          </div>
        )}

            <TradingViewWidget symbol={reportData.full_symbol} type="symbol-info" />

        <ShareCard
          symbol={reportData.symbol}
          security={reportData.security}
          securityJa={reportData.security_ja}
          sector={stockInfo?.["GICS Sector"]}
          highlights={reportData.highlights}
          earningsSurprise={reportData.earnings_surprise}
          analystRatings={reportData.analyst_ratings}
        />

        <div class="flex justify-end mt-4">
          <AiPromptButton reportData={reportData} analystSummary={analystSummary} stockInfo={stockInfo} />
        </div>

        <hr class="my-8 border-skin-line" />

        <nav class="toc bg-skin-fill/50 p-6 rounded-lg border border-skin-line mb-10">
            <h3 class="text-lg font-bold mb-4">目次</h3>
            <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-2 list-disc pl-5">
                <li><a href="#stock-chart" class="text-skin-accent hover:underline">{symbol}の株価推移・概要</a></li>
                <li><a href="#risk-return" class="text-skin-accent hover:underline">{symbol}のリスク・リターン分析</a></li>
                <li><a href="#peers" class="text-skin-accent hover:underline">{symbol}の同業種・競合</a></li>
                <li><a href="#sector-peers" class="text-skin-accent hover:underline">{symbol}の同セクター他社</a></li>
                <li><a href="#ranks" class="text-skin-accent hover:underline">{symbol}のランキング</a></li>
                <li><a href="#performance" class="text-skin-accent hover:underline">{symbol}のパフォーマンス比較</a></li>
                <li><a href="#earnings-highlights" class="text-skin-accent hover:underline">{symbol}の直近決算・財務ハイライト</a></li>
                {transcripts.length > 0 && (
                  <li><a href="#earnings-transcript" class="text-skin-accent hover:underline">{symbol}の決算説明会（全文和訳）</a></li>
                )}
                <li><a href="#next-earnings" class="text-skin-accent hover:underline">{symbol}の来期業績予想</a></li>
                <li><a href="#revenue-by-segment" class="text-skin-accent hover:underline">{symbol}のセグメント収益</a></li>
                <li><a href="#revenue-by-geography" class="text-skin-accent hover:underline">{symbol}の地域別収益</a></li>
                <li><a href="#fundamentals-detail" class="text-skin-accent hover:underline">{symbol}の財務データ推移</a></li>
                <li><a href="#analyst-ratings" class="text-skin-accent hover:underline">{symbol}のアナリスト評価</a></li>
                <li><a href="#dcf-valuation" class="text-skin-accent hover:underline">{symbol}のDCF理論株価分析</a></li>
                <li><a href="#japan-brokers" class="text-skin-accent hover:underline">日本の証券会社での取り扱い</a></li>
            </ul>
        </nav>

        <section id="stock-chart">
