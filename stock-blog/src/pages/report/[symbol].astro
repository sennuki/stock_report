                          <th class="px-3 py-3 text-right font-bold bg-skin-accent/10">TV</th>
                        </tr>
                      </thead>
                      <tbody class="divide-y divide-skin-line">
                        <tr>
                          <td class="px-3 py-3 font-medium bg-skin-fill/5">予想FCF</td>
