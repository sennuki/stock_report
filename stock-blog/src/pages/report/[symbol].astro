---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import stocks from "@/data/stocks.json";
import fs from "node:fs";
import path from "node:path";
import ChartJs from "@/components/report/ChartJs.astro";
import TradingViewWidget from "@/components/report/TradingViewWidget.astro";
import PeerLinks from "@/components/report/PeerLinks.astro";

export async function getStaticPaths() {
  // Use stocks.json as the source of truth for symbols
  return (stocks as any[]).map((stock: any) => ({
    params: { symbol: stock.Symbol_YF },
  }));
}

const { symbol } = Astro.params;
const jsonPath = path.join(process.cwd(), "public", "reports", `${symbol}.json`);

let reportData: any = null;
let lastUpdated: string = "";

if (fs.existsSync(jsonPath)) {
  const stats = fs.statSync(jsonPath);
  lastUpdated = new Intl.DateTimeFormat("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(stats.mtime);

  let content = fs.readFileSync(jsonPath, "utf-8");
  // Fix invalid JSON produced by Python's json.dump (NaN to null)
  content = content.replace(/\bNaN\b/g, "null");
  reportData = JSON.parse(content);
}

const stockInfo = (stocks as any[]).find((s: any) => s.Symbol_YF === symbol);
const title = `${symbol} (${stockInfo?.Security || ''}) 銘柄分析：株価・PER・配当利回り・ファンダメンタル分析`;
const description = `${symbol} (${stockInfo?.Security || ''}) の最新株価、PER、配当利回り、財務推移などのファンダメンタルデータを網羅。投資判断に役立つ分析レポートを定期的に更新しています。`;

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

// Helper to translate grades to "Japanese (English)"
const translateGrade = (grade: string) => {
  if (!grade) return "---";
  const g = grade.toLowerCase();
  if (g.includes('strong buy')) return `強気買い (${grade})`;
  if (g.includes('buy') || g.includes('outperform') || g.includes('overweight')) return `買い (${grade})`;
  if (g.includes('hold') || g.includes('neutral') || g.includes('equal-weight') || g.includes('market perform')) return `中立 (${grade})`;
  if (g.includes('sell') || g.includes('underperform') || g.includes('underweight')) return `売り (${grade})`;
  if (g.includes('strong sell')) return `強い売り (${grade})`;
  return grade;
};

// Calculate Analyst Summary in frontmatter to avoid template parsing issues with "<"
let analystSummary = null;
if (reportData?.analyst_ratings) {
  const r = reportData.analyst_ratings;
  const total = (r.strongBuy || 0) + (r.buy || 0) + (r.hold || 0) + (r.sell || 0) + (r.strongSell || 0);
  const score = total > 0 
    ? ((r.strongBuy || 0) * 1 + (r.buy || 0) * 2 + (r.hold || 0) * 3 + (r.sell || 0) * 4 + (r.strongSell || 0) * 5) / total 
    : 0;
  
  let assessment = "不明";
  let assessmentColor = "text-gray-500";
  if (score > 0 && score <= 1.5) { assessment = "強気買い (Strong Buy)"; assessmentColor = "text-green-600"; }
  else if (score > 1.5 && score <= 2.5) { assessment = "買い (Buy)"; assessmentColor = "text-green-500"; }
  else if (score > 2.5 && score <= 3.5) { assessment = "中立 (Hold)"; assessmentColor = "text-gray-500"; }
  else if (score > 3.5 && score <= 4.5) { assessment = "売り (Sell)"; assessmentColor = "text-red-500"; }
  else if (score > 4.5) { assessment = "強い売り (Strong Sell)"; assessmentColor = "text-red-700"; }

  analystSummary = { 
    total, 
    score, 
    assessment, 
    assessmentColor, 
    ratings: r,
    targetHigh: r.targetHighPrice,
    targetLow: r.targetLowPrice,
    targetMean: r.targetMeanPrice,
    targetMedian: r.targetMedianPrice,
    currentPrice: r.currentPrice,
    opinions: r.numberOfAnalystOpinions
  };
}
---

<Layout title={title} description={description}>
  <Header />
  
  <main id="main-content" class="w-full px-4 py-8 max-w-app mx-auto">
    <div class="mb-6">
       <a href={base} class="text-skin-accent hover:underline inline-flex items-center">
         <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
         </svg>
         銘柄一覧に戻る
       </a>
    </div>

    {!reportData ? (
        <div class="report-content bg-skin-card p-10 rounded-lg border border-skin-line shadow-sm text-center">
          <p class="text-xl">レポートが見つかりません: {symbol}</p>
          <p class="mt-4 text-gray-500">データ生成プロセスを実行してください。</p>
        </div>
    ) : (
      <div class="report-content bg-skin-card p-4 sm:p-8 rounded-lg border border-skin-line shadow-sm">
        <h1 class="text-3xl font-bold mb-2">銘柄分析レポート: {reportData.symbol} ({reportData.security})</h1>
        {lastUpdated && (
          <div class="flex items-center text-sm text-gray-500 mb-6 bg-skin-fill/30 px-3 py-1.5 rounded-md border border-skin-line w-fit">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 text-skin-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>最終更新日: {lastUpdated} <span class="mx-2 text-skin-line">|</span> 米国市場閉場後、全銘柄を毎日自動更新</span>
          </div>
        )}

            <TradingViewWidget symbol={reportData.full_symbol} type="symbol-info" />

        <hr class="my-8 border-skin-line" />

        <nav class="toc bg-skin-fill/50 p-6 rounded-lg border border-skin-line mb-10">
            <h3 class="text-lg font-bold mb-4">目次</h3>
            <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-2 list-disc pl-5">
                <li><a href="#stock-chart" class="text-skin-accent hover:underline">{symbol}の株価推移・概要</a></li>
                <li><a href="#risk-return" class="text-skin-accent hover:underline">{symbol}のリスク・リターン分析</a></li>
                <li><a href="#peers" class="text-skin-accent hover:underline">{symbol}の同業種・競合</a></li>
                <li><a href="#sector-peers" class="text-skin-accent hover:underline">{symbol}の同セクター他社</a></li>
                <li><a href="#performance" class="text-skin-accent hover:underline">{symbol}のパフォーマンス比較</a></li>
                <li><a href="#fundamentals" class="text-skin-accent hover:underline">{symbol}のファンダメンタルズ分析 (概要)</a></li>
                <li><a href="#fundamentals-detail" class="text-skin-accent hover:underline">{symbol}の財務データ推移 (詳細)</a></li>
                <li><a href="#analyst-ratings" class="text-skin-accent hover:underline">{symbol}のアナリスト評価 (直近)</a></li>
            </ul>
        </nav>

        <section id="stock-chart">
          <h2 class="text-2xl font-bold mb-4 border-b pb-2">📈 {symbol}の株価推移・概要</h2>
                <TradingViewWidget symbol={reportData.full_symbol} type="symbol-overview" height={650} />
        </section>

        <section id="risk-return" class="mt-12">
          <h2 class="text-2xl font-bold mb-4 border-b pb-2">🎯 {symbol}のリスク・リターン分析</h2>
          <ChartJs chartData={reportData.charts.risk_return} id="chart-risk-return" height={550} />
        </section>

        <section id="peers" class="mt-12">
          <PeerLinks title={`🏢 ${symbol}の同業種・競合 (${reportData.sub_industry})`} peers={reportData.peers.sub_industry} />
        </section>

        <section id="sector-peers">
          <PeerLinks title={`🏭 ${symbol}の同セクター他社 (${reportData.sector})`} peers={reportData.peers.sector} collapsible={true} />
        </section>

        <hr class="my-12 border-skin-line" />

        <section id="performance">
          <h2 class="text-2xl font-bold mb-4 border-b pb-2">📈 {symbol}のパフォーマンス比較</h2>
          {reportData.charts.performance ? (
            <ChartJs chartData={reportData.charts.performance} id="chart-performance" />
          ) : (
            <TradingViewWidget 
              symbol={reportData.full_symbol} 
              type="advanced-chart" 
              height={600} 
              compareSymbols={[
                { symbol: `AMEX:${reportData.sector_etf}`, position: "SameScale" },
                { symbol: "FRED:SP500", position: "SameScale" }
              ]}
            />
          )}
        </section>

        <section id="fundamentals" class="mt-12">
          <h2 class="text-2xl font-bold mb-4 border-b pb-2">📊 {symbol}のファンダメンタルズ分析</h2>
          <TradingViewWidget symbol={reportData.full_symbol} type="financials" height={950} />
        </section>

        <section id="fundamentals-detail" class="mt-12">
          <h2 class="text-2xl font-bold mb-8 border-b pb-2">📈 {symbol}の財務データ推移 (詳細分析)</h2>

          <div id="balance-sheet" class="scroll-mt-20 my-24">
            <ChartJs chartData={reportData.charts.bs} id="chart-bs" title="貸借対照表" />
          </div>

          <div id="income-statement" class="scroll-mt-20 my-24">
            <ChartJs chartData={reportData.charts.is} id="chart-is" title="損益計算書" />
          </div>

          <div id="cash-flow" class="scroll-mt-20 my-24">
            <ChartJs chartData={reportData.charts.cf} id="chart-cf" title="キャッシュフロー" />
          </div>

          <div id="shareholder-return" class="scroll-mt-20 my-24">
            <ChartJs chartData={reportData.charts.tp} id="chart-tp" title="株主還元" />
          </div>

          <div id="dividend-history" class="scroll-mt-20 my-24">
            <ChartJs chartData={reportData.charts.dps} id="chart-dps" title="1株あたり配当金" />
            <p class="text-sm text-gray-500 mt-24 block relative z-10">※「権利落日別」タブでは、当時の株価に基づいた予想配当利回り（年換算）も表示しています。</p>
          </div>
        </section>

        <hr class="my-12 border-skin-line" />

        <section id="analyst-ratings" class="mt-12">
          <h2 class="text-2xl font-bold mb-6 border-b pb-2">🎯 {symbol}のアナリスト評価 (直近)</h2>
          {analystSummary ? (
            <div class="space-y-8">
              {/* Summary Card */}
              <div class="bg-skin-fill/20 p-6 rounded-lg border border-skin-line flex flex-col sm:flex-row justify-around items-center text-center gap-6">
                <div>
                  <div class="text-sm opacity-70 mb-1">総合評価</div>
                  <div class={`text-2xl font-bold ${analystSummary.assessmentColor}`}>{analystSummary.assessment}</div>
                </div>
                <div class="w-px h-10 bg-skin-line hidden sm:block"></div>
                <div>
                  <div class="text-sm opacity-70 mb-1">平均スコア</div>
                  <div class="text-2xl font-bold text-skin-base">{analystSummary.score.toFixed(2)} <span class="text-sm font-normal opacity-50">/ 5.0</span></div>
                </div>
                <div class="w-px h-10 bg-skin-line hidden sm:block"></div>
                <div>
                  <div class="text-sm opacity-70 mb-1">アナリスト数</div>
                  <div class="text-2xl font-bold text-skin-base">{analystSummary.total}人</div>
                </div>
              </div>

              <div class="space-y-6">
                {[
                  { label: "強気買い (Strong Buy)", key: "strongBuy", color: "text-green-600" },
                  { label: "買い (Buy)", key: "buy", color: "text-green-500" },
                  { label: "中立 (Hold)", key: "hold", color: "text-gray-500" },
                  { label: "売り (Sell)", key: "sell", color: "text-red-500" },
                  { label: "強い売り (Strong Sell)", key: "strongSell", color: "text-red-700" }
                ].map((rating) => (
                  <div class="rating-row">
                    <div class="flex justify-between items-center mb-2">
                      <span class={`font-bold ${rating.color}`}>{rating.label}</span>
                      <span class="text-sm font-medium">{analystSummary.ratings[rating.key] || 0}人</span>
                    </div>
                    <div class="flex flex-wrap gap-0.5 text-lg leading-none opacity-80">
                      {Array.from({ length: analystSummary.ratings[rating.key] || 0 }).map(() => (
                        <span title={rating.label}>👤</span>
                      ))}
                      {(!analystSummary.ratings[rating.key] || analystSummary.ratings[rating.key] === 0) && (
                        <span class="text-gray-300 text-sm italic">該当なし</span>
                      )}
                    </div>
                  </div>
                ))}
              </div>

              {/* Target Price Section */}
              {analystSummary.targetMean && (
                <div class="mt-12 bg-skin-fill/20 p-6 rounded-lg border border-skin-line">
                  <h3 class="text-xl font-bold mb-6 text-center">🎯 目標株価 (Target Price)</h3>
                  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 text-center">
                    <div>
                      <div class="text-sm opacity-70 mb-1">平均目標株価</div>
                      <div class="text-2xl font-bold text-skin-accent">${analystSummary.targetMean.toFixed(2)}</div>
                      {analystSummary.currentPrice && (
                        <div class={`text-sm mt-1 font-semibold ${analystSummary.targetMean > analystSummary.currentPrice ? 'text-green-600' : 'text-red-600'}`}>
                          {((analystSummary.targetMean / analystSummary.currentPrice - 1) * 100).toFixed(1)}% {analystSummary.targetMean > analystSummary.currentPrice ? '上昇余地' : '下落予想'}
                        </div>
                      )}
                    </div>
                    <div>
                      <div class="text-sm opacity-70 mb-1">最高目標株価</div>
                      <div class="text-xl font-bold text-green-600">${analystSummary.targetHigh.toFixed(2)}</div>
                    </div>
                    <div>
                      <div class="text-sm opacity-70 mb-1">最低目標株価</div>
                      <div class="text-xl font-bold text-red-600">${analystSummary.targetLow.toFixed(2)}</div>
                    </div>
                    <div>
                      <div class="text-sm opacity-70 mb-1">現在価格</div>
                      <div class="text-xl font-bold opacity-80">${analystSummary.currentPrice?.toFixed(2) || '---'}</div>
                    </div>
                  </div>
                  <div class="mt-6 pt-6 border-t border-skin-line/30 flex justify-between items-center text-sm opacity-70">
                    <span>アナリスト予想数: {analystSummary.opinions || '---'}人</span>
                    <span>中央値: ${analystSummary.targetMedian?.toFixed(2) || '---'}</span>
                  </div>
                </div>
              )}

              {/* Recent Analyst Rating Changes */}
              {reportData.rating_changes && reportData.rating_changes.length > 0 && (
                <div class="mt-12 overflow-x-auto bg-skin-fill/10 p-4 rounded-lg border border-skin-line">
                  <h3 class="text-xl font-bold mb-4 px-2">📑 最近のレーティング変更</h3>
                  <table class="min-w-full divide-y divide-skin-line text-sm">
                    <thead class="bg-skin-fill/20">
                      <tr>
                        <th scope="col" class="px-4 py-3 text-left font-semibold">日付</th>
                        <th scope="col" class="px-4 py-3 text-left font-semibold">調査会社</th>
                        <th scope="col" class="px-4 py-3 text-left font-semibold">格付け</th>
                        <th scope="col" class="px-4 py-3 text-left font-semibold">アクション</th>
                        <th scope="col" class="px-4 py-3 text-right font-semibold">目標株価 (新/旧)</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-skin-line">
                      {reportData.rating_changes.map((change: any) => (
                        <tr class="hover:bg-skin-fill/10">
                          <td class="px-4 py-3 whitespace-nowrap opacity-80">{change.GradeDate}</td>
                          <td class="px-4 py-3 font-medium">{change.Firm}</td>
                          <td class="px-4 py-3">
                            <span class={`font-bold ${
                              change.ToGrade?.toLowerCase().includes('buy') || change.ToGrade?.toLowerCase().includes('outperform') || change.ToGrade?.toLowerCase().includes('overweight') 
                              ? 'text-green-600' : 
                              change.ToGrade?.toLowerCase().includes('sell') || change.ToGrade?.toLowerCase().includes('underperform') || change.ToGrade?.toLowerCase().includes('underweight')
                              ? 'text-red-600' : 'text-skin-base opacity-70'
                            }`}>
                              {translateGrade(change.ToGrade)}
                            </span>
                          </td>
                          <td class="px-4 py-3 italic opacity-70">
                            {(() => {
                              const action = change.Action?.toLowerCase();
                              let text = change.Action || '---';
                              let colorClass = '';
                              
                              if (action === 'up') {
                                text = `格上げ (up)`;
                                colorClass = 'text-green-600 font-semibold not-italic';
                              } else if (action === 'down') {
                                text = `格下げ (down)`;
                                colorClass = 'text-red-600 font-semibold not-italic';
                              } else if (action === 'main') {
                                text = `維持 (main)`;
                              } else if (action === 'reit') {
                                text = `再確認 (reit)`;
                              } else if (action === 'init') {
                                text = `新規開始 (init)`;
                              }
                              
                              return <span class={colorClass}>{text}</span>;
                            })()}
                          </td>
                          <td class="px-4 py-3 text-right whitespace-nowrap">
                            <div class="flex items-center justify-end gap-1.5">
                              {change.priorPriceTarget && (
                                <span class="text-xs opacity-50">${change.priorPriceTarget}</span>
                              )}
                              {change.priorPriceTarget && change.currentPriceTarget && (
                                <span class="text-xs opacity-30">→</span>
                              )}
                              {change.currentPriceTarget ? (
                                <span class={`font-bold ${
                                  change.priorPriceTarget 
                                  ? (change.currentPriceTarget > change.priorPriceTarget ? 'text-green-600' : change.currentPriceTarget < change.priorPriceTarget ? 'text-red-600' : '')
                                  : ''
                                }`}>
                                  ${change.currentPriceTarget}
                                </span>
                              ) : (
                                !change.priorPriceTarget && <span class="opacity-30">---</span>
                              )}
                            </div>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}

              <p class="text-xs text-gray-400 mt-8">
                ※平均スコアは 1.0(強気買い)から5.0(強い売り)の範囲で算出しています。<br />
                ※アナリストの推奨評価の合計人数を表示しています。投資の最終判断はご自身で行ってください。
              </p>
            </div>
          ) : (
            <p class="text-gray-500">アナリスト評価データは現在利用できません。</p>
          )}
        </section>
      </div>
    )}
  </main>
  <Footer />
</Layout>

<style>
  .report-content {
    color: var(--color-text-base);
  }
  .report-content h2 {
    margin-top: 2.5rem;
    color: var(--color-text-base);
  }
  .scroll-mt-20 {
    scroll-margin-top: 5rem;
  }
  .list-circle {
    list-style-type: circle;
  }
</style>
