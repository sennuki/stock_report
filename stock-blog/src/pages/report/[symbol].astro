                            <>
                              {signalRows.map(([label, hint, key], i) => (
                                <tr class={i % 2 === 0 ? "bg-skin-fill/5" : ""}>
                                  <td class="px-4 py-2 opacity-70">{label} <span class="text-[10px] font-normal opacity-50 block leading-tight">※{hint}</span></td>
                                  <td class="px-4 py-2 text-right font-medium">{fmtSignal(key)}</td>
                                </tr>
                              ))}
                              <tr class="font-bold border-t-2 border-skin-line">
                                <td class="px-4 py-2 opacity-70 text-skin-base">将来成長率 (1-5年) <span class="text-[10px] font-normal opacity-50 block leading-tight">※各シグナルを {fmt(bounds.floor)}〜{fmt(bounds.cap)} の範囲に丸めた上で、中央値を採用</span></td>
                                <td class="px-4 py-2 text-right text-skin-accent">{fmt(reportData.dcf_valuation.growth_1_5y)}</td>
                              </tr>
                            </>
