---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import stocks from "@/data/stocks.json";
import fs from "node:fs";
import path from "node:path";
import ChartJs from "@/components/report/ChartJs.astro";
import TradingViewWidget from "@/components/report/TradingViewWidget.astro";
import PeerLinks from "@/components/report/PeerLinks.astro";

export async function getStaticPaths() {
  // Use stocks.json as the source of truth for symbols
  return (stocks as any[]).map((stock: any) => ({
    params: { symbol: stock.Symbol_YF },
  }));
}

const { symbol } = Astro.params;
const jsonPath = path.join(process.cwd(), "public", "reports", `${symbol}.json`);

let reportData: any = null;
let lastUpdated: string = "";

if (fs.existsSync(jsonPath)) {
  const stats = fs.statSync(jsonPath);
  lastUpdated = new Intl.DateTimeFormat("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(stats.mtime);

  let content = fs.readFileSync(jsonPath, "utf-8");
  // Fix invalid JSON produced by Python's json.dump (NaN to null)
  content = content.replace(/\bNaN\b/g, "null");
  reportData = JSON.parse(content);
}

const stockInfo = (stocks as any[]).find((s: any) => s.Symbol_YF === symbol);
const title = `${symbol} (${stockInfo?.Security || ''}) 銘柄分析：株価・PER・配当利回り・ファンダメンタル分析`;
const description = `${symbol} (${stockInfo?.Security || ''}) の最新株価、PER、配当利回り、財務推移などのファンダメンタルデータを網羅。投資判断に役立つ分析レポートを定期的に更新しています。`;

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

// Helper to translate grades to "Japanese (English)"
const translateGrade = (grade: string) => {
  if (!grade) return "---";
  const g = grade.toLowerCase();
  if (g.includes('strong buy')) return `強気買い (${grade})`;
  if (g.includes('buy') || g.includes('outperform') || g.includes('overweight')) return `買い (${grade})`;
  if (g.includes('hold') || g.includes('neutral') || g.includes('equal-weight') || g.includes('market perform')) return `中立 (${grade})`;
  if (g.includes('sell') || g.includes('underperform') || g.includes('underweight')) return `売り (${grade})`;
  if (g.includes('strong sell')) return `強い売り (${grade})`;
  return grade;
};

// Calculate Analyst Summary in frontmatter to avoid template parsing issues with "<"
let analystSummary = null;
if (reportData?.analyst_ratings) {
  const r = reportData.analyst_ratings;
  const total = (r.strongBuy || 0) + (r.buy || 0) + (r.hold || 0) + (r.sell || 0) + (r.strongSell || 0);
  const score = total > 0 
    ? ((r.strongBuy || 0) * 1 + (r.buy || 0) * 2 + (r.hold || 0) * 3 + (r.sell || 0) * 4 + (r.strongSell || 0) * 5) / total 
    : 0;
  
  let assessment = "不明";
  let assessmentColor = "text-gray-500";
  if (score > 0 && score <= 1.5) { assessment = "強気買い (Strong Buy)"; assessmentColor = "text-green-600"; }
  else if (score > 1.5 && score <= 2.5) { assessment = "買い (Buy)"; assessmentColor = "text-green-500"; }
  else if (score > 2.5 && score <= 3.5) { assessment = "中立 (Hold)"; assessmentColor = "text-gray-500"; }
  else if (score > 3.5 && score <= 4.5) { assessment = "売り (Sell)"; assessmentColor = "text-red-500"; }
  else if (score > 4.5) { assessment = "強い売り (Strong Sell)"; assessmentColor = "text-red-700"; }

  analystSummary = { 
    total, 
    score, 
    assessment, 
    assessmentColor, 
    ratings: r,
    targetHigh: r.targetHighPrice,
    targetLow: r.targetLowPrice,
    targetMean: r.targetMeanPrice,
    targetMedian: r.targetMedianPrice,
    currentPrice: r.currentPrice,
    opinions: r.numberOfAnalystOpinions
  };
}
---

<Layout title={title} description={description}>
  <Header />
  
  <main id="main-content" class="w-full px-4 py-8 max-w-app mx-auto">
    <div class="mb-6">
       <a href={base} class="text-skin-accent hover:underline inline-flex items-center">
         <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
         </svg>
         銘柄一覧に戻る
       </a>
    </div>

    {!reportData ? (
        <div class="report-content bg-skin-card p-10 rounded-lg border border-skin-line shadow-sm text-center">
          <p class="text-xl">レポートが見つかりません: {symbol}</p>
          <p class="mt-4 text-gray-500">データ生成プロセスを実行してください。</p>
        </div>
    ) : (
      <div class="report-content bg-skin-card p-4 sm:p-8 rounded-lg border border-skin-line shadow-sm">
        <h1 class="text-3xl font-bold mb-2">銘柄分析レポート: {reportData.symbol} ({reportData.security})</h1>
        {lastUpdated && (
          <div class="flex items-center text-sm text-gray-500 mb-6 bg-skin-fill/30 px-3 py-1.5 rounded-md border border-skin-line w-fit">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 text-skin-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>最終更新日: {lastUpdated} <span class="mx-2 text-skin-line">|</span> 米国市場閉場後、全銘柄を毎日自動更新</span>
          </div>
        )}

            <TradingViewWidget symbol={reportData.full_symbol} type="symbol-info" />

        <hr class="my-8 border-skin-line" />

        <nav class="toc bg-skin-fill/50 p-6 rounded-lg border border-skin-line mb-10">
            <h3 class="text-lg font-bold mb-4">目次</h3>
            <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-2 list-disc pl-5">
                <li><a href="#stock-chart" class="text-skin-accent hover:underline">{symbol}の株価推移・概要</a></li>
                <li><a href="#risk-return" class="text-skin-accent hover:underline">{symbol}のリスク・リターン分析</a></li>
                <li><a href="#peers" class="text-skin-accent hover:underline">{symbol}の同業種・競合</a></li>
                <li><a href="#sector-peers" class="text-skin-accent hover:underline">{symbol}の同セクター他社</a></li>
                <li><a href="#performance" class="text-skin-accent hover:underline">{symbol}のパフォーマンス比較</a></li>
                <li><a href="#earnings-highlights" class="text-skin-accent hover:underline">{symbol}の直近決算・財務ハイライト</a></li>
                <li><a href="#next-earnings" class="text-skin-accent hover:underline">{symbol}の来期業績予想</a></li>
                <li><a href="#fundamentals" class="text-skin-accent hover:underline">{symbol}のファンダメンタルズ分析 (概要)</a></li>
                <li><a href="#fundamentals-detail" class="text-skin-accent hover:underline">{symbol}の財務データ推移 (詳細)</a></li>
                <li><a href="#analyst-ratings" class="text-skin-accent hover:underline">{symbol}のアナリスト評価 (直近)</a></li>
                <li><a href="#japan-brokers" class="text-skin-accent hover:underline">日本の証券会社での取り扱い</a></li>
            </ul>
        </nav>

        <section id="stock-chart">
          <h2 class="text-2xl font-bold mb-4 border-b pb-2">📈 {symbol}の株価推移・概要</h2>
                <TradingViewWidget symbol={reportData.full_symbol} type="symbol-overview" height={650} />
        </section>

        <section id="risk-return" class="mt-12">
          <h2 class="text-2xl font-bold mb-4 border-b pb-2">🎯 {symbol}のリスク・リターン分析</h2>
          <ChartJs chartData={reportData.charts.risk_return} id="chart-risk-return" height={550} />
          <div class="text-xs text-gray-500 mt-4 space-y-3">
            <p>※過去1年間の日次リターンデータに基づき、以下の式で年率換算しています：</p>
            <div class="flex flex-col gap-3 pl-4 py-3 border-l-2 border-skin-line/30 bg-skin-fill/5">
              <div class="flex items-center gap-4">
                <span class="font-bold w-24 shrink-0 text-gray-600 dark:text-gray-400">X軸 (リスク)</span>
                <span class="text-base font-serif tracking-wider">
                  <span class="italic font-bold">σ</span><sub>annual</sub> = <span class="italic font-bold">σ</span><sub>daily</sub> × &radic;<span class="border-t border-current pt-[1px]">252</span>
                </span>
              </div>
              <div class="flex items-center gap-4">
                <span class="font-bold w-24 shrink-0 text-gray-600 dark:text-gray-400">Y軸 (リターン)</span>
                <span class="text-base font-serif tracking-wider">
                  <span class="italic font-bold">R</span><sub>annual</sub> = <span class="italic font-bold">μ</span><sub>daily</sub> × 252
                </span>
              </div>
            </div>
            <div class="pt-2">
              ※ ここで <span class="italic font-bold font-serif">σ</span><sub>daily</sub> は日次リターンの標準偏差、<span class="italic font-bold font-serif">μ</span><sub>daily</sub> は日次リターンの平均、252は米国の年間市場営業日数を表します。
            </div>
          </div>
        </section>

        <section id="peers" class="mt-12">
          <PeerLinks title={`🏢 ${symbol}の同業種・競合 (${reportData.sub_industry})`} peers={reportData.peers.sub_industry} />
        </section>

        <section id="sector-peers">
          <PeerLinks title={`🏭 ${symbol}の同セクター他社 (${reportData.sector})`} peers={reportData.peers.sector} collapsible={true} />
        </section>

        <hr class="my-12 border-skin-line" />

        <section id="performance">
          <h2 class="text-2xl font-bold mb-4 border-b pb-2">📈 {symbol}のパフォーマンス比較</h2>
          {reportData.charts.performance ? (
            <ChartJs chartData={reportData.charts.performance} id="chart-performance" />
          ) : (
            <TradingViewWidget 
              symbol={reportData.full_symbol} 
              type="advanced-chart" 
              height={600} 
              compareSymbols={[
                { symbol: `AMEX:${reportData.sector_etf}`, position: "SameScale" },
                { symbol: "FRED:SP500", position: "SameScale" }
              ]}
            />
          )}
        </section>

        <section id="earnings-highlights" class="mt-12">
          <h2 class="text-2xl font-bold mb-6 border-b pb-2">💡 {symbol}の直近決算・財務ハイライト</h2>
          {reportData.highlights ? (
            <div class="space-y-6">
              {/* Latest Result (Surprise) */}
              {reportData.earnings_surprise && (
                <div class="bg-skin-fill/30 p-5 rounded-lg border-2 border-skin-accent/30 shadow-sm">
                  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                    <div>
                      <h3 class="text-lg font-bold flex items-center gap-2">
                        <span class="text-xl">📢</span> 直近の四半期決算実績 (EPSサプライズ)
                      </h3>
                      <p class="text-sm opacity-70 mt-1">決算発表日: {reportData.earnings_surprise.date}</p>
                    </div>
                    <div class="flex items-center gap-6">
                      <div class="text-center">
                        <div class="text-xs opacity-60 uppercase tracking-wider mb-1">市場予想</div>
                        <div class="text-xl font-bold opacity-80">
                          {reportData.earnings_surprise.estimate !== null ? `$${reportData.earnings_surprise.estimate.toFixed(2)}` : '---'}
                        </div>
                      </div>
                      <div class="text-2xl font-light opacity-30">→</div>
                      <div class="text-center">
                        <div class="text-xs opacity-60 uppercase tracking-wider mb-1">実績 (EPS)</div>
                        <div class={`text-2xl font-bold ${reportData.earnings_surprise.actual >= (reportData.earnings_surprise.estimate || 0) ? 'text-green-600' : 'text-red-600'}`}>
                          {reportData.earnings_surprise.actual !== null ? `$${reportData.earnings_surprise.actual.toFixed(2)}` : '---'}
                        </div>
                      </div>
                      <div class={`px-3 py-1.5 rounded-md font-bold text-sm ${reportData.earnings_surprise.surprise_pct >= 0 ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
                        {reportData.earnings_surprise.surprise_pct !== null ? `${reportData.earnings_surprise.surprise_pct >= 0 ? '+' : ''}${reportData.earnings_surprise.surprise_pct.toFixed(2)}%` : '---'}
                        <span class="ml-1">{reportData.earnings_surprise.surprise_pct >= 0 ? 'Beat!' : 'Miss'}</span>
                      </div>
                    </div>
                  </div>
                </div>
              )}

              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                <div class="bg-skin-fill/20 p-4 rounded-lg border border-skin-line">
                  <div class="text-sm opacity-70 mb-1 flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    売上高成長率 (YoY)
                  </div>
                  <div class={`text-2xl font-bold ${reportData.highlights.revenue_growth > 0 ? 'text-green-600' : 'text-red-600'}`}>
                    {reportData.highlights.revenue_growth !== null ? (reportData.highlights.revenue_growth * 100).toFixed(1) + '%' : '---'}
                  </div>
                </div>

                <div class="bg-skin-fill/20 p-4 rounded-lg border border-skin-line">
                  <div class="text-sm opacity-70 mb-1 flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                    </svg>
                    利益成長率 (YoY)
                  </div>
                  <div class={`text-2xl font-bold ${reportData.highlights.earnings_growth > 0 ? 'text-green-600' : 'text-red-600'}`}>
                    {reportData.highlights.earnings_growth !== null ? (reportData.highlights.earnings_growth * 100).toFixed(1) + '%' : '---'}
                  </div>
                </div>

                <div class="bg-skin-fill/20 p-4 rounded-lg border border-skin-line">
                  <div class="text-sm opacity-70 mb-1 flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2h2a2 2 0 002-2zM9 19h10a2 2 0 002-2v-3a2 2 0 00-2-2h-3z" />
                    </svg>
                    営業利益率
                  </div>
                  <div class="text-2xl font-bold text-skin-base">
                    {reportData.highlights.operating_margins !== null ? (reportData.highlights.operating_margins * 100).toFixed(1) + '%' : '---'}
                  </div>
                </div>

                <div class="bg-skin-fill/20 p-4 rounded-lg border border-skin-line">
                  <div class="text-sm opacity-70 mb-1 flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z" />
                    </svg>
                    ROE (自己資本利益率)
                  </div>
                  <div class="text-2xl font-bold text-skin-base">
                    {reportData.highlights.roe !== null ? (reportData.highlights.roe * 100).toFixed(1) + '%' : '---'}
                  </div>
                </div>

                <div class="bg-skin-fill/20 p-4 rounded-lg border border-skin-line">
                  <div class="text-sm opacity-70 mb-1">予想PER</div>
                  <div class="text-2xl font-bold text-skin-accent">
                    {reportData.highlights.pe_forward !== null ? reportData.highlights.pe_forward.toFixed(1) + 'x' : '---'}
                  </div>
                  <div class="text-xs opacity-50 mt-1">実績PER: {reportData.highlights.pe_ttm !== null ? reportData.highlights.pe_ttm.toFixed(1) + 'x' : '---'}</div>
                </div>

                <div class="bg-skin-fill/20 p-4 rounded-lg border border-skin-line">
                  <div class="text-sm opacity-70 mb-1">EPS (直近12ヶ月)</div>
                  <div class="text-2xl font-bold text-skin-base">
                    {reportData.highlights.eps_ttm !== null ? '$' + reportData.highlights.eps_ttm.toFixed(2) : '---'}
                  </div>
                  <div class="text-xs opacity-50 mt-1">予想EPS: {reportData.highlights.eps_forward !== null ? '$' + reportData.highlights.eps_forward.toFixed(2) : '---'}</div>
                </div>

                <div class="bg-skin-fill/20 p-4 rounded-lg border border-skin-line">
                  <div class="text-sm opacity-70 mb-1">配当利回り</div>
                  <div class="text-2xl font-bold text-skin-base">
                    {reportData.highlights.dividend_yield !== null ? (reportData.highlights.dividend_yield * 100).toFixed(2) + '%' : '実績なし'}
                  </div>
                  <div class="text-xs opacity-50 mt-1">配当性向: {reportData.highlights.payout_ratio !== null ? (reportData.highlights.payout_ratio * 100).toFixed(1) + '%' : '---'}</div>
                </div>

                <div class="bg-skin-fill/20 p-4 rounded-lg border border-skin-line">
                  <div class="text-sm opacity-70 mb-1">負債比率 (D/E)</div>
                  <div class="text-2xl font-bold text-skin-base">
                    {reportData.highlights.debt_to_equity !== null ? reportData.highlights.debt_to_equity.toFixed(1) + '%' : '---'}
                  </div>
                  <div class="text-xs opacity-50 mt-1">流動比率: {reportData.highlights.current_ratio !== null ? reportData.highlights.current_ratio.toFixed(2) : '---'}</div>
                </div>
              </div>
              <p class="text-xs text-gray-500 mt-4 italic">
                ※YoY (Year over Year): 前年同期比。前年の同じ時期と比較した成長率を示します。季節的な変動を排除して、企業の純粋な成長性を判断するための重要な指標です。
              </p>
            </div>
          ) : (
            <p class="text-gray-500 italic">ハイライトデータは現在利用できません。データ生成を再実行してください。</p>
          )}
        </section>

        <section id="next-earnings" class="mt-12">
          <h2 class="text-2xl font-bold mb-6 border-b pb-2">🚀 {symbol}の来期業績予想 (コンセンサス)</h2>
          
          {reportData.next_earnings ? (
            <div class="space-y-6">
              <div class="bg-skin-fill/20 p-6 sm:p-8 rounded-lg border border-skin-line shadow-sm flex flex-col md:flex-row justify-between items-center gap-8">
                <div class="flex-grow">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="p-3 bg-skin-accent/10 rounded-full text-skin-accent">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    </div>
                    <div>
                      <h3 class="text-xl font-bold">次回決算発表予定</h3>
                      <p class="text-gray-500">{reportData.next_earnings.date} (予定)</p>
                    </div>
                  </div>
                  <p class="text-sm opacity-80 leading-relaxed">
                    市場アナリストによる次回の四半期決算予想（コンセンサス）です。実績がこの予想を上回る（ポジティブサプライズ）か、下回るかが、発表直後の株価に大きく影響します。
                  </p>
                </div>

                <div class="flex items-center gap-8 bg-skin-fill/30 p-6 rounded-xl border border-skin-line min-w-[280px] justify-center">
                  <div class="text-center">
                    <div class="text-xs opacity-60 uppercase tracking-wider mb-2">市場予想 (EPS)</div>
                    <div class="text-4xl font-black text-skin-accent">
                      {reportData.next_earnings.estimate !== null ? `$${reportData.next_earnings.estimate.toFixed(2)}` : '---'}
                    </div>
                    {reportData.earnings_surprise && reportData.next_earnings.estimate !== null && reportData.earnings_surprise.actual !== null && (
                      <div class={`mt-3 inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold ${reportData.next_earnings.estimate > reportData.earnings_surprise.actual ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
                        {reportData.next_earnings.estimate > reportData.earnings_surprise.actual ? '↑ 前期比 増益予想' : '↓ 前期比 減益予想'}
                      </div>
                    )}
                  </div>
                </div>
              </div>

              {/* Detailed Consensus Grid */}
              {reportData.consensus && (
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  {/* EPS Consensus */}
                  <div class="bg-skin-fill/10 p-6 rounded-lg border border-skin-line">
                    <h4 class="font-bold mb-4 flex items-center gap-2">
                      <span class="text-blue-500">💎</span> 1株あたり利益 (EPS) 予想
                    </h4>
                    <div class="space-y-4">
                      <div class="flex justify-between items-center py-2 border-b border-skin-line/30">
                        <span class="text-sm opacity-70">コンセンサス (平均)</span>
                        <span class="font-bold text-lg text-skin-accent">${reportData.consensus.earnings?.["0q"]?.avg?.toFixed(2) || '---'}</span>
                      </div>
                      <div class="flex justify-between items-center py-2 border-b border-skin-line/30">
