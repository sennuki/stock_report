                            }`}>
                              {translateGrade(change.ToGrade)}
                            </span>
                          </td>
                          <td class="px-4 py-3 italic opacity-70">
                            {(() => {
                              const action = change.Action?.toLowerCase();
                              let text = change.Action || '---';
                              let colorClass = '';
                              
                              if (action === 'up') {
                                text = `格上げ (up)`;
                                colorClass = 'text-green-600 font-semibold not-italic';
                              } else if (action === 'down') {
                                text = `格下げ (down)`;
                                colorClass = 'text-red-600 font-semibold not-italic';
                              } else if (action === 'main') {
                                text = `維持 (main)`;
                              } else if (action === 'reit') {
                                text = `再確認 (reit)`;
                              } else if (action === 'init') {
                                text = `新規開始 (init)`;
                              }
                              
                              return <span class={colorClass}>{text}</span>;
                            })()}
                          </td>
                          <td class="px-4 py-3 text-right whitespace-nowrap opacity-70">
                            {change.PriceAtRating ? `$${change.PriceAtRating.toFixed(2)}` : '---'}
                          </td>
                          <td class="px-4 py-3 text-right whitespace-nowrap">
                            <div class="flex items-center justify-end gap-1.5">
                              {change.priorPriceTarget > 0 && (
                                <span class="text-xs opacity-50">${change.priorPriceTarget}</span>
                              )}
                              {change.priorPriceTarget > 0 && change.currentPriceTarget > 0 && (
                                <span class="text-xs opacity-30">→</span>
                              )}
                              {change.currentPriceTarget > 0 ? (
                                <span class={`font-bold ${
                                  change.priorPriceTarget > 0
                                  ? (change.currentPriceTarget > change.priorPriceTarget ? 'text-green-600' : change.priorPriceTarget > change.currentPriceTarget ? 'text-red-600' : '')
                                  : ''
                                }`}>
                                  ${change.currentPriceTarget}
                                </span>
                              ) : (
                                !(change.priorPriceTarget > 0) ? (
                                  <span class="opacity-30">---</span>
                                ) : null
                              )}
                            </div>
                          </td>
                          <td class="px-4 py-3 text-right whitespace-nowrap">
                            {upsideAtRating !== null ? (
                              <div class="flex flex-col items-end">
                                <span class={`font-bold ${upsideAtRating > 0 ? 'text-green-600' : upsideAtRating < 0 ? 'text-red-600' : ''}`}>
                                  {upsideAtRating > 0 ? '+' : ''}{upsideAtRating.toFixed(1)}%
                                </span>
                                <span class="text-[10px] opacity-40 leading-none mt-0.5">判定時</span>
                              </div>
                            ) : (
                              <span class="opacity-30">---</span>
                            )}
                          </td>
                          <td class="px-4 py-3 text-right whitespace-nowrap bg-skin-fill/5">
                            {upsideCurrent !== null ? (
                              <span class={`font-bold ${upsideCurrent > 0 ? 'text-green-600' : upsideCurrent < 0 ? 'text-red-600' : ''}`}>
                                {upsideCurrent > 0 ? '+' : ''}{upsideCurrent.toFixed(1)}%
                              </span>
                            ) : (
                              <span class="opacity-30">---</span>
                            )}
                          </td>
                        </tr>
                      )})}
                    </tbody>
                  </table>
                </div>
              )}

              <p class="text-xs text-gray-400 mt-8">
