                        </tr>
                        <tr>
                          <td class="px-3 py-3 font-medium bg-skin-fill/5">現在価値 (割引後)</td>
                          {reportData.dcf_valuation.projections.map((p: any) => (
                            <td class="px-3 py-3 text-right font-medium text-skin-accent">${(p.discounted_fcf / 1e9).toFixed(2)}B</td>
                          ))}
                          <td class="px-3 py-3 text-right font-bold bg-skin-accent/10 text-skin-accent">${(reportData.dcf_valuation.npv_tv / 1e9).toFixed(2)}B</td>
                        </tr>
                        <tr class="bg-skin-fill/10">
