                            <>
                              <tr class="bg-skin-fill/5"><td class="px-4 py-2 opacity-70">EPS 9Y CAGR <span class="text-[10px] font-normal opacity-50 block leading-tight">※過去9年間の TTM EPS 年率成長</span></td><td class="px-4 py-2 text-right font-medium">{fmt(reportData.dcf_valuation.cagr_details?.eps_9y_cagr)}</td></tr>
                              <tr><td class="px-4 py-2 opacity-70">売上高 CAGR (3Y)</td><td class="px-4 py-2 text-right font-medium">{fmt(reportData.dcf_valuation.cagr_details?.revenue)}</td></tr>
                              <tr class="bg-skin-fill/5"><td class="px-4 py-2 opacity-70">フリーキャッシュフロー CAGR (3Y)</td><td class="px-4 py-2 text-right font-medium">{fmt(reportData.dcf_valuation.cagr_details?.fcf)}</td></tr>
                              <tr><td class="px-4 py-2 opacity-70">EBITDA CAGR (3Y)</td><td class="px-4 py-2 text-right font-medium">{fmt(reportData.dcf_valuation.cagr_details?.ebitda)}</td></tr>
                              <tr class="bg-skin-fill/5"><td class="px-4 py-2 opacity-70">純利益 CAGR (3Y)</td><td class="px-4 py-2 text-right font-medium">{fmt(reportData.dcf_valuation.cagr_details?.net_income)}</td></tr>
                              <tr class="font-bold border-t-2 border-skin-line"><td class="px-4 py-2 opacity-70 text-skin-base">将来成長率 (1-5年) <span class="text-[10px] font-normal opacity-50 block leading-tight">※EPS 9Y CAGR を 5%〜20% にクリップ (旧方式)</span></td><td class="px-4 py-2 text-right text-skin-accent">{fmt(reportData.dcf_valuation.growth_1_5y)}</td></tr>
                            </>
                          )}
                          <tr><td class="px-4 py-2 opacity-70">将来成長率 (6年目) <span class="text-[10px] font-normal opacity-50 block leading-tight">※6-10年は線形補間で終端成長率へ収束</span></td><td class="px-4 py-2 text-right font-medium">{fmt(reportData.dcf_valuation.growth_6_10y)}</td></tr>
                          <tr class="bg-skin-fill/5"><td class="px-4 py-2 opacity-70">永続成長率 (Terminal)</td><td class="px-4 py-2 text-right font-medium">{fmt(reportData.dcf_valuation.terminal_growth)}</td></tr>
                        </tbody>
                      </table>
                    </div>
                  </div>
                  );
                })()}
              </div>

              {/* Cash Flow Projections Table */}
              {reportData.dcf_valuation.projections && (
                <div class="space-y-4">
                  <h3 class="text-lg font-bold flex items-center gap-2">
                    <span class="material-symbols-outlined text-purple-500" aria-hidden="true">calendar_today</span>
