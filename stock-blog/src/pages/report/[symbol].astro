                  const bounds = reportData.dcf_valuation.growth_winsorize_bounds;
                  const useMultiSignal = raw && clipped && bounds;
                  // 各シグナルの表示: 丸めた値を主に出し、上下限で値が動いていれば
                  // "(元の値 X%)" を付記して透明性を持たせる。
                  const fmt = (v: number | null | undefined) =>
                    v != null ? (v * 100).toFixed(2) + '%' : '---';
                  const fmtSignal = (key: string) => {
                    const r = raw?.[key];
                    const c = clipped?.[key];
                    if (c == null) return '---';
                    const cStr = fmt(c);
                    if (r == null || Math.abs(r - c) < 1e-9) return cStr;
                    return cStr + ` (元 ${fmt(r)})`;
                  };
                  const signalRows: Array<[string, string, string]> = useMultiSignal ? [
                    ["EPS 9Y CAGR", "過去9年間の TTM EPS 年率成長", "eps_9y"],
                    ["売上高 CAGR (3Y)", "直近3年の年率成長", "revenue_3y"],
                    ["フリーキャッシュフロー CAGR (3Y)", "直近3年の年率成長", "fcf_3y"],
                    ["EBITDA CAGR (3Y)", "直近3年の年率成長", "ebitda_3y"],
                    ["アナリスト長期予想", "アナリストの 5 年 EPS 成長予想 (取得不可の場合は直近 YoY で代替)", "analyst_5y"],
                    ["内部成長率", "ROE × (1 - 配当性向) で算出するファンダ理論上の持続可能な成長率", "sustainable"],
                  ] : [];
                  return (
                  <div class="space-y-4">
                    <h3 class="text-lg font-bold flex items-center gap-2">
                      <span class="material-symbols-outlined text-green-500" aria-hidden="true">show_chart</span>
