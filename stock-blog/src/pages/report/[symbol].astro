---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import stocks from "@/data/stocks.json";
import TradingViewWidget from "@/components/report/TradingViewWidget.astro";
import ChartJs from "@/components/report/ChartJs.astro";
import PeerLinks from "@/components/report/PeerLinks.astro";
import { calculateDCF } from "@/utils/finance";
import { transformRawToReport } from "@/utils/report-generator";

const { symbol } = Astro.params;

let rawData: any = null;
let reportData: any = null;
let dcfResult: any = null;
let errorDetail: string = "";

// 1. R2からデータを取得
try {
  // Astro v6 で環境変数にアクセスするための最新の手段
  const runtime = Astro.locals as any;
  const bucket = runtime?.runtime?.env?.STOCK_DATA || runtime?.env?.STOCK_DATA;

  if (bucket) {
    // R2から取得
    const object = await bucket.get(`reports/${symbol}.json`) || await bucket.get(`raw/${symbol}.json`);
    if (object) {
      const content = await object.text();
      // Fix potential NaN issues in JSON
      rawData = JSON.parse(content.replace(/\bNaN\b/g, "null"));
      
      // Transform raw data to full report format
      reportData = transformRawToReport(rawData);
      
      // Use Python-calculated DCF if available, otherwise fallback to JS calculation
      dcfResult = reportData.dcf_valuation || calculateDCF(rawData);
    } else {
      errorDetail = `R2に ${symbol}.json が見つかりませんでした。`;
    }
  } else {
    errorDetail = "R2バケット(STOCK_DATA)のバインドに失敗しました。wrangler.jsoncを確認してください。";
  }
} catch (e: any) {
  errorDetail = `システムエラー: ${e.message}`;
}

const title = reportData ? `${reportData.symbol} (${reportData.security_ja || reportData.security}) 銘柄レポート` : `${symbol} 銘柄レポート`;
---

<Layout title={title}>
  <Header />
  <main class="w-full px-4 py-8 max-w-app mx-auto">
    {!reportData ? (
      <div class="bg-skin-card p-10 rounded-lg border border-skin-line shadow-sm">
        <h1 class="text-2xl font-bold text-center mb-4">分析レポートを表示できません</h1>
        <div class="bg-gray-100 p-6 rounded-md font-mono text-sm overflow-auto text-red-600">
          <p class="font-bold mb-2 uppercase">Debug Info:</p>
          <p>{errorDetail}</p>
          <hr class="my-4 border-gray-300" />
          <p class="text-gray-600 text-xs italic">
            解決しない場合は、R2に reports/{symbol}.json が存在するか確認してください。
          </p>
        </div>
      </div>
    ) : (
      <div class="report-content bg-skin-card p-6 rounded-lg border border-skin-line shadow-sm">
        <h1 class="text-3xl font-bold mb-6">{reportData.symbol} ({reportData.security_ja || reportData.security})</h1>
        
        <TradingViewWidget symbol={reportData.full_symbol} type="symbol-info" />

        <section class="mt-12">
          <h2 class="text-2xl font-bold mb-4 border-b pb-2">会社概要</h2>
          <p class="text-skin-base whitespace-pre-wrap leading-relaxed">
            {reportData.business_summary_ja || "概要データは準備中です。"}
          </p>
        </section>

        {dcfResult && (
          <section id="dcf-valuation" class="mt-12">
            <h2 class="text-2xl font-bold mb-6 border-b pb-2 flex items-center gap-2">
              DCF理論株価分析
            </h2>
            <div class="bg-skin-fill/20 p-6 sm:p-8 rounded-lg border-2 border-skin-accent/30 shadow-sm">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
                <div>
                  <h3 class="text-xl font-bold mb-4 text-skin-accent">理論株価 (Fair Price)</h3>
                  <div class="text-6xl font-black text-skin-base">${dcfResult.fair_price.toFixed(2)}</div>
                  <div class="mt-6">
                    <div class={`inline-flex items-center px-4 py-2 rounded-full font-bold text-lg ${dcfResult.fair_price > dcfResult.current_price ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
                      乖離率: {((dcfResult.fair_price / dcfResult.current_price - 1) * 100).toFixed(1)}%
                      ({dcfResult.fair_price > dcfResult.current_price ? '割安' : '割高'})
                    </div>
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                  <div class="bg-skin-fill/30 p-4 rounded-xl border border-skin-line text-center">
                    <div class="text-xs opacity-60 uppercase mb-1">割引率 (WACC)</div>
                    <div class="text-xl font-bold text-skin-accent">{(dcfResult.wacc * 100).toFixed(2)}%</div>
                  </div>
                  <div class="bg-skin-fill/30 p-4 rounded-xl border border-skin-line text-center">
                    <div class="text-xs opacity-60 uppercase mb-1">推定成長率</div>
                    <div class="text-xl font-bold text-skin-accent">{(dcfResult.growth_1_5y * 100).toFixed(2)}%</div>
                  </div>
                </div>
              </div>
            </div>
          </section>
        )}

        {reportData.charts?.is && (
          <section class="mt-12">
            <h2 class="text-2xl font-bold mb-4 border-b pb-2">業績推移</h2>
            <div class="h-[400px]">
              <ChartJs chartData={reportData.charts.is} id="chart-is" />
            </div>
          </section>
        )}

        <section id="fundamentals" class="mt-12">
          <h2 class="text-2xl font-bold mb-4 border-b pb-2">財務分析 (TradingView)</h2>
          <TradingViewWidget symbol={reportData.full_symbol} type="financials" height={800} />
        </section>
      </div>
    )}
  </main>
  <Footer />
</Layout>
